	// CRIAR TABELA .CSV
	"CRIAR TABELA .CSV": {
		"prefix": "pytabcsv",
		"body": [
			"import pyodbc",
			"import csv",
			"",
			"instancia = '${1:NOME_DA_INSTÂNCIA}'",
			"banco = '${2:NOME_DO_BANCO}'",
			"caminho_csv = r'${3:C:\\Users\\CAMINHO\\ARQUIVO.csv}'",
			"nome_tabela = '${4:TABELA}' # NOME DA TABELA A SER CRIADA",
			"",
			"try:",
			"    conn = pyodbc.connect(",
			"        f'DRIVER={{ODBC Driver 17 for SQL Server}};'",
			"        f'SERVER=localhost\\\\{instancia};'",
			"        'Trusted_Connection=yes;'",
			"    )",
			"    cursor = conn.cursor()",
			"    ",
			"    cursor.execute(f\"USE {banco}\")",
			"    ",
			"    # Lê primeira linha com encoding 'utf-8-sig' (remove BOM automaticamente)",
			"    with open(caminho_csv, 'r', encoding='utf-8-sig') as f:",
			"        leitor = csv.reader(f, delimiter=';')  # Seu CSV usa ponto e vírgula?",
			"        colunas_originais = next(leitor)",
			"    ",
			"    # Encurta nomes das colunas (máximo 50 caracteres)",
			"    colunas = []",
			"    for col in colunas_originais:",
			"        # Remove espaços extras e encurta",
			"        col_limpa = col.strip().replace(' ', '_')[:50]",
			"        colunas.append(col_limpa)",
			"    ",
			"    # Cria a tabela com nomes encurtados",
			"    colunas_sql = ', '.join([f\"[{col}] NVARCHAR(MAX)\" for col in colunas])",
			"    cursor.execute(f\"DROP TABLE IF EXISTS {nome_tabela}\")",
			"    cursor.execute(f\"CREATE TABLE {nome_tabela} ({colunas_sql})\")",
			"    print(f\"✅ Tabela {nome_tabela} criada com {len(colunas)} colunas\")",
			"    ",
			"    # Insere os dados",
			"    with open(caminho_csv, 'r', encoding='utf-8-sig') as f:",
			"        leitor = csv.reader(f, delimiter=';')",
			"        next(leitor)",
			"        ",
			"        for linha in leitor:",
			"            # Garante que a linha tem o mesmo número de colunas",
			"            while len(linha) < len(colunas):",
			"                linha.append('')",
			"            placeholders = ', '.join(['?' for _ in range(len(colunas))])",
			"            cursor.execute(f\"INSERT INTO {nome_tabela} VALUES ({placeholders})\", linha[:len(colunas)])",
			"    ",
			"    conn.commit()",
			"    ",
			"    cursor.execute(f\"SELECT COUNT(*) FROM {nome_tabela}\")",
			"    total = cursor.fetchone()[0]",
			"    print(f\"✅ {total} linhas inseridas\")",
			"    ",
			"    cursor.execute(f\"SELECT TOP 1 * FROM {nome_tabela}\")",
			"    print(\"\\n📀 Primeira linhas:\")",
			"    for row in cursor.fetchall():",
			"        print(f\"   {row}\")",
			"    ",
			"    cursor.close()",
			"    conn.close()",
			"    ",
			"except Exception as e:",
			"    print(f\"Erro: {e}\")",
			""
		],
		"description": "Criar tabela no SQL importando dados de um arquivo .csv"
	},

	//Procurar Termo em BD/Tabelas/Colunas (NÃO DADOS) LEVE
	"Procurar Termo em BD/Tabelas/Colunas (NÃO DADOS) LEVE": {
		"prefix": "pybdfiltroleve",
		"body": [
			"#PROCURA PELO TERMO DETERMINADO EM TABELAS/COLUNAS",
			"import pyodbc",
			"",
			"termo = '${1:NOME114}'",
			"instancia = '${2:MSSQLSERVER01}'",
			"",
			"print(f\"🔍 Varredura completa por '{termo}' em {instancia}\\n\")",
			"",
			"try:",
			"    conn = pyodbc.connect(",
			"        f'DRIVER={{ODBC Driver 17 for SQL Server}};'",
			"        f'SERVER=localhost\\\\{instancia};'",
			"        'Trusted_Connection=yes;'",
			"    )",
			"    cursor = conn.cursor()",
			"    ",
			"    # Script SQL que varre tudo",
			"    sql = f\"\"\"",
			"    DECLARE @SearchTerm NVARCHAR(100) = '{termo}';",
			"    DECLARE @Results TABLE (FoundIn NVARCHAR(500));",
			"    ",
			"    -- Buscar em nomes de bancos",
			"    INSERT INTO @Results",
			"    SELECT 'database: ' + name",
			"    FROM sys.databases",
			"    WHERE name LIKE '%' + @SearchTerm + '%' AND database_id > 4;",
			"    ",
			"    -- Para cada banco, buscar em tabelas e colunas",
			"    DECLARE @db NVARCHAR(128);",
			"    DECLARE db_cursor CURSOR FOR",
			"    SELECT name FROM sys.databases WHERE database_id > 4;",
			"    ",
			"    OPEN db_cursor;",
			"    FETCH NEXT FROM db_cursor INTO @db;",
			"    ",
			"    WHILE @@FETCH_STATUS = 0",
			"    BEGIN",
			"        DECLARE @sql NVARCHAR(MAX) = '",
			"            USE [' + @db + '];",
			"            ",
			"            INSERT INTO @Results",
			"            SELECT ''' + @db + '.table: '' + TABLE_SCHEMA + ''.'' + TABLE_NAME",
			"            FROM INFORMATION_SCHEMA.TABLES",
			"            WHERE TABLE_NAME LIKE ''%'' + @SearchTerm + ''%'';",
			"            ",
			"            INSERT INTO @Results",
			"            SELECT ''' + @db + '.column: '' + TABLE_SCHEMA + ''.'' + TABLE_NAME + ''.'' + COLUMN_NAME",
			"            FROM INFORMATION_SCHEMA.COLUMNS",
			"            WHERE COLUMN_NAME LIKE ''%'' + @SearchTerm + ''%'';",
			"        ';",
			"        EXEC sp_executesql @sql, N'@SearchTerm NVARCHAR(100)', @SearchTerm;",
			"        ",
			"        FETCH NEXT FROM db_cursor INTO @db;",
			"    END",
			"    ",
			"    CLOSE db_cursor;",
			"    DEALLOCATE db_cursor;",
			"    ",
			"    SELECT * FROM @Results;",
			"    \"\"\"",
			"    ",
			"    cursor.execute(sql)",
			"    resultados = cursor.fetchall()",
			"    ",
			"    if resultados:",
			"        print(\"✅ ENCONTRADO EM:\\n\")",
			"        for r in resultados:",
			"            print(f\"   📌 {r[0]}\")",
			"    else:",
			"        print(f\"❌ Nada encontrado para '{termo}'\")",
			"    ",
			"    cursor.close()",
			"    conn.close()",
			"    ",
			"except Exception as e:",
			"    print(f\"Erro: {e}\")",
			""
		],
		"description": "Procurar Termo em Tabelas/Colunas LEVE"
	},

	//Procurar TERMO em Todos os dados das Tabelas (NÃO BD/TABELAS) PESADO
	"Procurar TERMO em Todos os dados das Tabelas (NÃO BD/TABELAS) PESADO": {
		"prefix": "pybdfiltropesado",
		"body": [
			"#PROCURA PELO TERMO DETERMINADO EM TODOS OS DADOS DA INSTÂNCIA",
			"import pyodbc",
			"",
			"termo = '${1:DIGITE_DADO}' # O que você quer encontrar",
			"instancias = ['${2:DIGITE_INSTÂNCIA}'] # instâncias que quer varrer",
			"",
			"def buscar_nos_dados(instancia, termo):",
			"    print(f\"\\n🔍 Buscando dado '{termo}' em {instancia}...\\n\")",
			"    ",
			"    try:",
			"        conn = pyodbc.connect(",
			"            f'DRIVER={{ODBC Driver 17 for SQL Server}};'",
			"            f'SERVER=localhost\\\\{instancia};'",
			"            'Trusted_Connection=yes;'",
			"        )",
			"        cursor = conn.cursor()",
			"        ",
			"        cursor.execute(\"SELECT name FROM sys.databases WHERE database_id > 4\")",
			"        bancos = [b.name for b in cursor.fetchall()]",
			"        ",
			"        encontrado = False",
			"        ",
			"        for banco in bancos:",
			"            cursor.execute(f\"USE [{banco}]\")",
			"            ",
			"            # Pega tabelas e colunas que são texto (varchar, nvarchar)",
			"            cursor.execute(\"\"\"",
			"                SELECT ",
			"                    t.name AS tabela,",
			"                    c.name AS coluna",
			"                FROM sys.tables t",
			"                JOIN sys.columns c ON t.object_id = c.object_id",
			"                WHERE c.system_type_id IN (167, 231, 239)  -- varchar, nvarchar, varchar(max)",
			"            \"\"\")",
			"            ",
			"            tabelas_colunas = cursor.fetchall()",
			"            ",
			"            for tc in tabelas_colunas:",
			"                try:",
			"                    query = f\"\"\"",
			"                        SELECT TOP 1 * ",
			"                        FROM [{banco}].[dbo].[{tc.tabela}]",
			"                        WHERE [{tc.coluna}] LIKE ?",
			"                    \"\"\"",
			"                    cursor.execute(query, (f'%{termo}%',))",
			"                    resultado = cursor.fetchone()",
			"                    ",
			"                    if resultado:",
			"                        print(f\"   🎯 ENCONTRADO: {banco}.dbo.{tc.tabela}.{tc.coluna}\")",
			"                        encontrado = True",
			"                except:",
			"                    pass",
			"        ",
			"        if not encontrado:",
			"            print(f\"   ❌ Nada encontrado para '{termo}'\")",
			"        ",
			"        cursor.close()",
			"        conn.close()",
			"        ",
			"    except Exception as e:",
			"        print(f\"   ⚠️ Erro: {e}\")",
			"",
			"for inst in instancias:",
			"    buscar_nos_dados(inst, termo)",
			""
		],
		"description": "Procurar Termo nos DADOS das Tabelas (NÃO BD/TABELAS) PESADO"
},


