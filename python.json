	//Filtrar Programas no Windows
	"Filtrar Programas no Windows": {
		"prefix": "pysysprogfilt",
		"body": [
			"${2:import winreg}",
			"",
			"x = \"${1:digite o nome do programa}\"",
			"",
			"print(f\"=== PROGRAMAS RELACIONADOS A {x} ===\\n\")",
			"",
			"# Local 1: App Paths (executáveis)",
			"caminho_apps = r\"SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\"",
			"",
			"try:",
			"    chave = winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, caminho_apps)",
			"    ",
			"    for i in range(100):",
			"        try:",
			"            nome_programa = winreg.EnumKey(chave, i)",
			"            # Filtro usando a variável x",
			"            if x in nome_programa.lower():",
			"                subchave = winreg.OpenKey(chave, nome_programa)",
			"                caminho_exe = winreg.QueryValueEx(subchave, \"\")[0]",
			"                print(f\"📌 {nome_programa}\")",
			"                print(f\"   → {caminho_exe}\\n\")",
			"                winreg.CloseKey(subchave)",
			"        except:",
			"            pass",
			"    winreg.CloseKey(chave)",
			"except:",
			"    print(\"Erro ao acessar App Paths\")",
			"",
			"# Local 2: Uninstall (programas instalados)",
			"print(f\"=== PROGRAMAS RELACIONADOS A {x} (SEM DUPLICATAS) ===\\n\")",
			"",
			"caminho_uninstall = r\"SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\"",
			"programas_vistos = set()  # ← Para evitar duplicatas",
			"",
			"try:",
			"    chave = winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, caminho_uninstall)",
			"    ",
			"    for i in range(200):",
			"        try:",
			"            subkey_name = winreg.EnumKey(chave, i)",
			"            subchave = winreg.OpenKey(chave, subkey_name)",
			"            ",
			"            try:",
			"                nome = winreg.QueryValueEx(subchave, \"DisplayName\")[0]",
			"                if x in nome.lower():",
			"                    # Verifica se já viu este programa",
			"                    if nome not in programas_vistos:",
			"                        programas_vistos.add(nome)",
			"                        print(f\"📦 {nome}\")",
			"                        ",
			"                        try:",
			"                            versao = winreg.QueryValueEx(subchave, \"DisplayVersion\")[0]",
			"                            print(f\"   Versão: {versao}\")",
			"                        except:",
			"                            pass",
			"                        print()",
			"            except:",
			"                pass",
			"            winreg.CloseKey(subchave)",
			"        except:",
			"            pass",
			"    winreg.CloseKey(chave)",
			"except Exception as e:",
			"    print(f\"Erro: {e}\")",
			"",
			"# Local 3: Drivers ODBC",
			"print(f\"\\n=== DRIVERS ODBC {x} ===\\n\")",
			"caminho_odbc = r\"SOFTWARE\\ODBC\\ODBCINST.INI\"",
			"",
			"try:",
			"    chave = winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, caminho_odbc)",
			"    ",
			"    for i in range(50):",
			"        try:",
			"            nome_driver = winreg.EnumKey(chave, i)",
			"            # Filtro usando a variável x",
			"            if x in nome_driver.lower():",
			"                subchave = winreg.OpenKey(chave, nome_driver)",
			"                ",
			"                print(f\"🔌 {nome_driver}\")",
			"                try:",
			"                    driver_dll = winreg.QueryValueEx(subchave, \"Driver\")[0]",
			"                    print(f\"   DLL: {driver_dll}\")",
			"                except:",
			"                    pass",
			"                try:",
			"                    versao = winreg.QueryValueEx(subchave, \"DriverODBCVer\")[0]",
			"                    print(f\"   Versão ODBC: {versao}\")",
			"                except:",
			"                    pass",
			"                print()",
			"                ",
			"                winreg.CloseKey(subchave)",
			"        except:",
			"            pass",
			"    winreg.CloseKey(chave)",
			"except:",
			"    print(\"Erro ao acessar drivers ODBC\")",
			""
		],
		"description": "Lista todos os programas do filtro que estejam instalados ou App Paths ou drivers ODBC via Windows Registry"
	},

	//Listar Todos Programas Instalados
	"Listar Todos Programas Instalados": {
		"prefix": "pysysproglist",
		"body": [
			"import winreg",
			"",
			"print(\"=== TODOS PROGRAMAS INSTALADOS (COMPLETO) ===\\n\")",
			"",
			"def listar_programas(reg_key, caminho):",
			"    programas = []",
			"    try:",
			"        chave = winreg.OpenKey(reg_key, caminho)",
			"        for i in range(500):",
			"            try:",
			"                subkey_name = winreg.EnumKey(chave, i)",
			"                subchave = winreg.OpenKey(chave, subkey_name)",
			"                try:",
			"                    nome = winreg.QueryValueEx(subchave, \"DisplayName\")[0]",
			"                    if nome and nome not in programas:",
			"                        programas.append(nome)",
			"                except:",
			"                    pass",
			"                winreg.CloseKey(subchave)",
			"            except:",
			"                break",
			"        winreg.CloseKey(chave)",
			"    except:",
			"        pass",
			"    return programas",
			"",
			"# Lista de locais onde programas podem estar registrados",
			"locais = [",
			"    (winreg.HKEY_LOCAL_MACHINE, r\"SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\"),",
			"    (winreg.HKEY_LOCAL_MACHINE, r\"SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\"),",
			"    (winreg.HKEY_CURRENT_USER, r\"SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\")",
			"]",
			"",
			"todos_programas = []",
			"",
			"for reg_key, caminho in locais:",
			"    todos_programas.extend(listar_programas(reg_key, caminho))",
			"",
			"# Remove duplicatas e ordena",
			"todos_programas = sorted(set(todos_programas))",
			"",
			"for p in todos_programas:",
			"    print(f\"📦 {p}\")",
			"",
			"print(f\"\\n✅ Total: {len(todos_programas)} programas instalados\")",
			""
		],
		"description": "Lista TODOS os programas instalados no Windows (HKLM 64/32 e HKCU) sem duplicatas e ordenado"
	},

