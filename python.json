//Varrer Bancos de Dados
	"Varrer Bancos de Dados": {
		"prefix": "pysysbdvarredura",
		"body": [
			"import pyodbc",
			"import winreg",
			"import socket",
			"",
			"print(\"=== INSTÂNCIAS SQL SERVER E BANCOS ===\\n\")",
			"",
			"# PASSO 1: Descobrir todas as instâncias instaladas",
			"caminho_reg = r\"SOFTWARE\\Microsoft\\Microsoft SQL Server\"",
			"nomes_instancias = []",
			"",
			"try:",
			"    chave = winreg.OpenKey(winreg.HKEY_LOCAL_MACHINE, caminho_reg)",
			"    nomes_instancias = winreg.QueryValueEx(chave, \"InstalledInstances\")[0]",
			"    winreg.CloseKey(chave)",
			"    print(f\"📋 Instâncias encontradas no registro: {nomes_instancias}\\n\")",
			"except:",
			"    print(\"⚠️ Não foi possível ler registro\\n\")",
			"",
			"# PASSO 2: Montar lista de strings de conexão",
			"# Pega o nome do computador automaticamente",
			"nome_computador = socket.gethostname()",
			"print(f\"💻 Nome do computador: {nome_computador}\\n\")",
			"",
			"# Lista de possíveis conexões (prioriza instâncias descobertas)",
			"instancias_conexao = [",
			"    \"localhost\",                    # sempre tenta",
			"    \".\",                           # ponto (mesmo que localhost)",
			"    f\"{nome_computador}\",          # nome do computador",
			"]",
			"",
			"# Adiciona as instâncias encontradas no registro",
			"for inst in nomes_instancias:",
			"    instancias_conexao.append(f\"localhost\\\\{inst}\")",
			"    instancias_conexao.append(f\"{nome_computador}\\\\{inst}\")",
			"",
			"# Remove duplicatas mantendo ordem",
			"vistas = set()",
			"instancias_conexao_unicas = []",
			"for inst in instancias_conexao:",
			"    if inst not in vistas:",
			"        vistas.add(inst)",
			"        instancias_conexao_unicas.append(inst)",
			"",
			"print(f\"🔍 Testando {len(instancias_conexao_unicas)} possíveis conexões...\\n\")",
			"",
			"# PASSO 3: Testar cada instância e listar bancos",
			"resultados = []",
			"",
			"for inst in instancias_conexao_unicas:",
			"    try:",
			"        conn = pyodbc.connect(",
			"            f'DRIVER={{ODBC Driver 17 for SQL Server}};'",
			"            f'SERVER={inst};'",
			"            'Trusted_Connection=yes;'",
			"            'Connection Timeout=3'",
			"        )",
			"        cursor = conn.cursor()",
			"        ",
			"        # Pega nome real da instância",
			"        cursor.execute(\"SELECT @@SERVERNAME\")",
			"        nome_real = cursor.fetchone()[0]",
			"        ",
			"        # Lista bancos do usuário",
			"        cursor.execute(\"\"\"",
			"            SELECT name, database_id, create_date",
			"            FROM sys.databases ",
			"            WHERE database_id > 4",
			"            ORDER BY name",
			"        \"\"\")",
			"        ",
			"        bancos = cursor.fetchall()",
			"        ",
			"        # Armazena resultado",
			"        resultados.append({",
			"            'conexao': inst,",
			"            'nome_real': nome_real,",
			"            'bancos': bancos",
			"        })",
			"        ",
			"        cursor.close()",
			"        conn.close()",
			"        ",
			"    except Exception as e:",
			"        # Ignora falhas de conexão silenciosamente",
			"        pass",
			"",
			"# PASSO 4: Exibir resultados",
			"if not resultados:",
			"    print(\"❌ Nenhuma instância SQL Server encontrada ou acessível\")",
			"else:",
			"    for i, r in enumerate(resultados):",
			"        print(f\"\\n{'='*60}\")",
			"        print(f\"🖥️  INSTÂNCIA: {r['nome_real']}\")",
			"        print(f\"   (conexão usada: {r['conexao']})\")",
			"        print('='*60)",
			"        ",
			"        if r['bancos']:",
			"            print(f\"📀 BANCOS DO USUÁRIO ({len(r['bancos'])}):\")",
			"            for b in r['bancos']:",
			"                print(f\"   • {b.name} (ID: {b.database_id})\")",
			"        else:",
			"            print(f\"📀 Nenhum banco de usuário encontrado\")",
			"            print(f\"   (apenas bancos do sistema)\")",
			"",
			"print(f\"\\n{'='*60}\")",
			"print(f\"✅ Total: {len(resultados)} instância(s) SQL Server ativa(s)\")",
			""
		],
		"description": "Varredura por Detecção automaticamente de instâncias SQL Server via registro e lista bancos de usuário"
	},

