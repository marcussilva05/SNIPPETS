        "    A.UA_ALOC,",
        "    W.NOMEUA AS NOMEUA_C_ALOC ,",
        "    A.CARGO_ALOC,",
        "    X.NM_CARGO AS CARGO_ALOC_DESC,",
        "    A.DTI_ALOC,",
