	  "    ${2:COLUNA} ${3:VARCHAR}(${4:100})",
    "    )",
	  "INSERT INTO #${1:BASE_TEMP} (${2:COLUNA}) VALUES",
	  "${5:('DADO1'),}",
    "${5:('DADO2'),}",
	  "${5:('ETC...'),}"
    ],
    "description": "INSERIR_DADOS_EM_TEMPORARIA"
  },

	// UNION_SEM_DUPLICATAS
  "UNION_SEM_DUPLICATAS": {
    "scope": "sql",
    "prefix": "ZUNION",
    "body": [
	  "${7:DROP TABLE IF EXISTS ${1:#BASE}_UNION}",
      "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
	  "INTO ${1:#BASE}_UNION",
	  "FROM ${5:#BASE1}",
	  "UNION",
	  "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
