// 00_FUNCIONAL_CRIAR
"00_FUNCIONAL_CRIAR": {
    "scope": "sql",
    "prefix": "Z00FUNC_CRIAR",
    "body": [
        "/*",
        "${1:0526}",
        "${2:0426} -- MES ANTERIOR",
        "[${3:052026}]",
        "*/",
        "",
        "$4USE CEPEA_SAS",
        "",
        "---------------------------------------------------------------------------------------------------- TEMPORÁRIAS --------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #FUNC",
        "DROP TABLE IF EXISTS #ID",
        "DROP TABLE IF EXISTS #CGRH",
        "DROP TABLE IF EXISTS #CGRHANT",
        "DROP TABLE IF EXISTS #ALOC",
        "DROP TABLE IF EXISTS #NIVEL",
        "DROP TABLE IF EXISTS #PESSOAL",
        "DROP TABLE IF EXISTS #ESCOLA",
        "DROP TABLE IF EXISTS #ARQ",
        "DROP TABLE IF EXISTS #CARGO",
        "DROP TABLE IF EXISTS #DISC",
        "DROP TABLE IF EXISTS #00UA",
        "DROP TABLE IF EXISTS #BFE",
        "",
        "SELECT * INTO #CGRH FROM CGRH_APOIO.DBO.BASE_SERVIDORES_ATIVOS_FINAL_${1:0526}",
        "SELECT * INTO #CGRHANT FROM CGRH_APOIO.DBO.BASE_SERVIDORES_ATIVOS_FINAL_${2:0426}",
        "SELECT * INTO #FUNC FROM SAS.[${3:052026}].TB_FUNCIONAL",
        "SELECT * INTO #ID FROM TB_ID_INTERNO_SERV",
        "SELECT * INTO #ALOC FROM SAS.[${3:052026}].[TB_UA_ALOCACAO]",
        "SELECT * INTO #NIVEL FROM NIVEL_FORMACAO${1:0526}",
        "SELECT * INTO #PESSOAL FROM SAS.[${3:052026}].TB_PESSOAL",
        "SELECT * INTO #ESCOLA FROM ESCOLAS${1:0526}",
        "SELECT * INTO #ARQ FROM ARQDEUA${1:0526}",
        "SELECT * INTO #CARGO FROM TAB_CARGO${1:0526}",
        "SELECT * INTO #DISC FROM DESENV.DBO.DISCIPLINA",
        "SELECT * INTO #00UA FROM [00_UA]",
        "SELECT * INTO #BFE FROM TAB_CODBFE",
        "",
        "----------------------------------------------------------- #JOIN1 -----------------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #JOIN1",
        "SELECT DISTINCT",
        "A.*    ,",
        "B.ID    ,",
        "C.*    ,",
        "D.POLO_C AS POLO_C_ANT,",
        "NULLIF(D.POLO_E, '') AS POLO_E_ANT,",
        "    E.CD_UA  AS UA_ALOC            ,",
        "    E.CD_CARGO  AS CARGO_ALOC         ,",
        "    E.DT_INI_VIG  AS DTI_ALOC       ,",
        "    E.DT_FIM_VIG  AS DTF_ALOC       ,",
        "    E.FL_SITUACAO AS SITUACAO_ALOC       , -- A (ATIVO) E (ESTÁVEIS) I (INATIVOS)",
        "    E.CD_IDENT_SIT_VINC AS VINCULO_ALOC , -- C (COMISSIONADOS) D (DESIGNADOS) T (TITULARES)",
        "F.FORMACAO,",
        "F.NIVEL_FORMACAO,",
        "    G.DT_SIT_REG,",
        "    G.NM_PESSOA AS NOME_SERVIDOR,",
        "    G.SG_UF_RG AS UF_RG,",
        "    G.ID_ORG_EMIS_RG AS ORGAO_RG,",
        "    G.DT_EMIS_RG,",
        "    G.DT_NASC,",
        "    G.SG_UF_NASC AS UF_NASC,",
        "    G.NM_MUN_NASC,",
        "    G.CD_EST_CIVIL,",
        "    G.QT_DEP_IR AS QTD_DEPENDENTES,",
        "    G.QT_DEP_SAL_FAM,",
        "    G.DT_INIC_SERV_PUBL,",
        "    G.DT_ANO_PRIM_EMPR,",
        "    G.CD_GRAU_ESCOL,",
        "    G.CD_SIT_ESCOL,",
        "    G.EN_PESSOA AS ENDERECO_RESID,",
        "    G.CD_CEP AS CEP,",
        "    G.NR_DIG_CEP AS DIG_CEP,",
        "    G.NM_BAIRRO AS BAIRRO,",
        "    G.NM_MUN_RESID,",
        "    G.SG_UF_END_PESSOA,",
        "    G.NR_PIS_PASEP AS PIS_PASEP,",
        "    G.NR_TIT_ELE AS TIT_ELEITOR,",
        "    G.CD_MUN_TIT_ELE,",
        "    G.SG_UF_TIT_ELE,",
        "    G.DT_EMIS_TIT_ELE,",
        "    G.CD_DDD,",
        "    G.NR_TEL,",
        "    G.CD_DDD_CEL,",
        "    G.NR_TEL_CEL,",
        "    G.DT_ANO_ENTR_BR,",
        "    G.ID_PAIS_ORIG,",
        "    G.NM_EMAIL AS EMAIL_PESSOAL,",
        "    G.NM_MAE,",
        "    G.NM_PAI,",
        "    G.TP_DEFICIENCIA,",
        "    G.FL_DEFIC_COND_LEI,",
        "    G.TP_ESPECIFICACAO_DEFICIENCIA,",
        "    G.TP_DEFICIENCIA_2,",
        "    G.TP_ESPECIFICACAO_DEFICIENCIA_2,",
        "    G.TP_DEFICIENCIA_3,",
        "    G.TP_ESPECIFICACAO_DEFICIENCIA_3,",
        "    G.FL_DEFICIENCIA_MULTIPLA,",
        "    G.FL_ALDEADO,",
        "    G.NM_EMAIL_INST,",
        "    G.NM_PESSOA_SOCIAL,",
        "    G.NM_EMAIL2 AS EMAIL_2",
        "INTO #JOIN1",
        "FROM #FUNC A",
        "FULL JOIN #ID B ON B.CPF = A.NR_CPF",
        "FULL JOIN #CGRH C ON C.ID_INTERNO = B.ID",
        "FULL JOIN #CGRHANT D ON D.ID_INTERNO = B.ID",
        "FULL JOIN #ALOC E ON E.NR_CPF = A.NR_CPF",
        "FULL JOIN #NIVEL F ON F.CPF = A.NR_CPF",
        "LEFT JOIN #PESSOAL G ON G.NR_CPF = A.NR_CPF",
        "WHERE A.CD_SIT_REG = 'A'",
        "",
        "-- (310405 linhas afetadas)",
        "",
        "----------------------------------------------------------- #JOIN2 -----------------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #JOIN2",
        "SELECT -- TOP 10000",
        "    CASE",
        "        WHEN A.CD_SIT_REG = 'A' THEN 'A - ATIVO'",
        "        ELSE A.CD_SIT_REG",
        "    END AS SITUACAO,",
        "    CASE",
        "       WHEN A.CD_IDENT_SIT_VINC_TIT = 'A' THEN 'A - ATIVO'",
        "       WHEN A.CD_IDENT_SIT_VINC_TIT = 'B' THEN 'B - BLOQUEADO'",
        "       WHEN A.CD_IDENT_SIT_VINC_TIT = 'C' THEN 'C - COMISSÃO'",
        "       WHEN A.CD_IDENT_SIT_VINC_TIT = 'D' THEN 'D - DESIGNADO'",
        "       WHEN A.CD_IDENT_SIT_VINC_TIT = 'E' THEN 'E - EXCLUÍDO'",
        "       WHEN A.CD_IDENT_SIT_VINC_TIT = 'F' THEN 'F - FALECIDO'",
        "       WHEN A.CD_IDENT_SIT_VINC_TIT = 'I' THEN 'I - INATIVO'",
