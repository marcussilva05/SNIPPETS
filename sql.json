        "    A.QTDE_ATS,",
        "    COALESCE(",
        "          CASE",
        "             WHEN A.ID_COR = 'A' THEN 'A - AMARELO'",
        "             WHEN A.ID_COR = 'B' THEN 'B - BRANCO'",
        "             WHEN A.ID_COR = 'I' THEN 'I - ÍNDIGENA'",
        "             WHEN A.ID_COR = 'N' THEN 'N - NEGRO'",
        "             WHEN A.ID_COR = 'P' THEN 'P - PARDO'",
        "             ELSE A.ID_COR",
        "          END,",
        "          ''",
        "           ) AS COR ,  ",
        "    A.FORMACAO,",
        "    A.NIVEL_FORMACAO,",
        "    A.DT_SIT_REG,   ",
        "    A.NR_RG AS RG,",
        "    A.UF_RG,",
        "    A.ORGAO_RG,",
        "    A.DT_EMIS_RG,",
        "    A.DT_NASC,",
        "    A.NM_MUN_NASC,",
        "    A.UF_NASC,",
        "    COALESCE(",
        "          CASE",
        "             WHEN A.CD_EST_CIVIL = 'A' THEN 'A - SEPARADO JUDICIALMENTE'",
        "             WHEN A.CD_EST_CIVIL = 'C' THEN 'C - CASADO'",
        "             WHEN A.CD_EST_CIVIL = 'D' THEN 'D - DESQUITADO'",
        "             WHEN A.CD_EST_CIVIL = 'E' THEN 'E - UNIÃO ESTÁVEL'   ",
        "             WHEN A.CD_EST_CIVIL = 'H' THEN 'H - UNIÃO ESTÁVEL HOMOAFETIVA'",
        "             WHEN A.CD_EST_CIVIL = 'R' THEN 'R - DIVORCIADO'",
        "             WHEN A.CD_EST_CIVIL = 'S' THEN 'S - SOLTEIRO'",
