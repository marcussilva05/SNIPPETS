// MAPEAMENTO_DATABRICKS_CRIAR 
"MAPEAMENTO_DATABRICKS_CRIAR": {
  "scope": "sql",
  "prefix": "BRIMAP_CRIAR",
  "body": [
    "SELECT ",
    "    DATE_FORMAT(t.created, 'yyyy-MM-dd') AS DT_CRIACAO,",
    "    DATE_FORMAT(t.last_altered, 'yyyy-MM-dd') AS DT_ULT_ALTERACAO,",
    "    t.table_catalog AS CATALOGO,",
    "    t.table_schema AS ESQUEMA,",
    "    t.table_name AS TABELA,",
    "    COUNT(c.column_name) AS COLUNAS,",
    "    ARRAY_JOIN(COLLECT_LIST(c.column_name), ', ') AS NOME_DAS_COLUNAS,",
    "    t.table_owner AS PROPRIETARIO,",
    "    CONCAT('SELECT * FROM ', t.table_catalog, '.', t.table_schema, '.', t.table_name, ' LIMIT 10') AS ENDERECO",
    "FROM system.information_schema.tables t",
    "JOIN system.information_schema.columns c ",
    "  ON t.table_catalog = c.table_catalog ",
    " AND t.table_schema = c.table_schema ",
    " AND t.table_name = c.table_name",
    "GROUP BY t.created, t.last_altered, t.table_catalog, t.table_schema, t.table_name, t.table_owner",
    "ORDER BY t.created DESC, t.last_altered DESC, CATALOGO, ESQUEMA, TABELA"
  ],
  "description": "MAPEAMENTO_DATABRICKS_CRIAR"
},

// MAPEAMENTO_DATABRICKS_CONSULTAR
"MAPEAMENTO_DATABRICKS_CONSULTAR": {
    "scope": "sql",
    "prefix": "Z00BRICKS",
    "body": [
        "USE CEPEA_SAS",
        "",
        "SELECT ",
        "    DT_CRIACAO,",
        "    DT_ULT_ALTERACAO,",
        "    CATALOGO,",
        "    ESQUEMA,",
        "    TABELA,",
        "    COLUNAS,",
        "    NOME_DAS_COLUNAS,",
        "    PROPRIETARIO,",
        "    ENDERECO         ",
        "FROM [00_BRICKS]",
        "-- WHERE ENDERECO LIKE '%ALOC%'",
        "-- OR NOME_DAS_COLUNAS LIKE '%ALOC%'",
        "ORDER BY DT_CRIACAO DESC, DT_ULT_ALTERACAO DESC, CATALOGO, ESQUEMA, TABELA"
    ],
    "description": "MAPEAMENTO_DATABRICKS_CONSULTAR"
},

