  "COLUNAS_NA_VERTICAL_SAS": {
    "scope": "sql",
    "prefix": "ZSYSCOLVSAS",
    "body": [
      "${5:USE ${1:SAS}                                    }",
      "SELECT",    
      "   COLUMN_NAME AS COLUNA",
      "FROM INFORMATION_SCHEMA.COLUMNS",
