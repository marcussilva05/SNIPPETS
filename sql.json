      "  AND TABLE_NAME = '${3:pap_ua}'  ${4:-- nome da tabela sem colchetes}",
      "ORDER BY ORDINAL_POSITION"
      ],
    "description": "TERMINAL COM COLUNAS_NA_VERTICAL_SAS"
  },

