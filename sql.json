  // 00_MAPEAMENTO_BD
  "00_MAPEAMENTO_BD": {
    "scope": "sql",
    "prefix": "ZMAP",
    "body": [
      "${3:SELECT                                          }",
      "   ANO_TABELA,",
      "   BD,",
      "   TABELA,",
      "   COLUNA,",
      "   END_COMPLETO",
      "FROM [dbo].[00_MAPEAMENTO_BD${1:03}26]",
