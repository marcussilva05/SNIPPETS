        "    A.DT_INIC_INTERRUP_CESS_COMIS AS DTI_MOTINTERRUP_COMIS,",
        "    A.DT_FIM_INTERRUP_CESS_COMIS AS DTF_MOTINTERRUP_COMIS,",
        "    A.CD_MOT_AFAST_COMIS AS MOTIAFAS_COMIS,",
        "    O.[COD-EVENTO] AS MOTIAFAS_COMIS_DESC ,",
        "    A.DT_INIC_MOT_AFAST_COMIS AS DTI_MOTIAFAS_COMIS,",
        "    A.DT_FIM_MOT_AFAST_COMIS AS DTF_MOTIAFAS_COMIS,",
        "    A.CD_MOT_LIC_COMIS AS MOTILICE_COMIS,",
        "    P.[COD-EVENTO] AS MOTILICE_COMIS_DESC,",
        "    A.DT_INIC_LIC_COMIS AS DTI_MOTILICE_COMIS,",
        "    A.DT_FIM_LIC_COMIS AS DTF_MOTILICE_COMIS,",
