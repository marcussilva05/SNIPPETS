  // COUNT
  "COUNT": {
    "scope": "sql",
    "prefix": "ZCOUNT",
    "body": [
      "COUNT(*) AS ${1:TOTAL} ${2:-- SUM(* OU COLUNA), AVG(* OU COLUNA), MAX(* OU COLUNA), MIN(* OU COLUNA) VEJA MAIS EM ZGROUP}",  
      ],
    "description": "CONTAR E AGRUPAR"
  },	

  // GROUP_BY
  "GROUP_BY": {
      "scope": "sql",
      "prefix": "ZGROUP",
      "body": [
      "${1:SELECT}",
      "     ${2:COLUNA1,}",
      "     COUNT(*) AS TOTAL -- SUM(* OU COLUNA), AVG(* OU COLUNA), MAX(* OU COLUNA), MIN(* OU COLUNA)",  
      "${3:FROM BASE}", 
      "${4:GROUP BY COLUNA1}",
      "${5:ORDER BY TOTAL DESC}"
      ],
      "description": "GROUP_BY"
  },

  // HAVING
  "HAVING": {
      "scope": "sql",
      "prefix": "ZHAVING",
      "body": [
      "${1:SELECT}",
      "     ${1:COLUNA1,}",
      "     ${1:COUNT(*) AS TOTAL, -- SUM(* OU COLUNA), AVG(* OU COLUNA), MAX(* OU COLUNA), MIN(* OU COLUNA)}", 
      "     ${1:AVG(PRECO) AS PRECO}",
      "${1:FROM BASE}", 
      "${1:GROUP BY COLUNA1}",
      "${1:HAVING COUNT(*) > 10 }",
      "   ${1:AND AVG(preco) > 50}",
      "${1:ORDER BY TOTAL DESC}"
      ],
      "description": "HAVING"
  },

