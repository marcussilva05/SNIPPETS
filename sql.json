  },
  // EXCLUIR_LINHAS_NULL
  "EXCLUIR_LINHAS_NULL": {
    "scope": "sql",
    "prefix": "ZEXCLLINULL",
    "body": [
      "DELETE FROM ${1:tabela}",
      "WHERE ${2:coluna1} IS NULL",
