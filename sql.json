        "-- (310405 linhas afetadas)",
        "",
        "----------------------------------------------------------- #ROWNUMB -----------------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #ROWNUMB;",
        "WITH BASE_RANK1 AS (",
        "   SELECT *",
        "   FROM #JOIN3",
        "),",
        "RANK1 AS (",
        "   SELECT *,",
        "      ROW_NUMBER() OVER (PARTITION BY CPF_DI ORDER BY CPF_DI DESC, DTI_EXERC_E DESC, SITUACAO_ALOC) AS RANK_CPF_DI -- ,",
        "      --ROW_NUMBER() OVER (PARTITION BY DTI_EXERC_E ORDER BY DTI_EXERC_E DESC) AS RANK_DTI_EXERC_E,",
        "      --ROW_NUMBER() OVER (PARTITION BY DTI_ALOC ORDER BY DTI_ALOC DESC) AS RANK_DTI_ALOC",
        "   FROM BASE_RANK1",
        ")",
        "SELECT *",
        "INTO #ROWNUMB",
        "FROM RANK1",
        "WHERE RANK_CPF_DI = 1            -- Primeira linha de cada CPF_DI",
        "   --OR RANK_DTI_EXERC_E = 1       -- Primeira linha de cada DTI_EXERC_E",
        "   --OR RANK_DTI_ALOC = 1          -- Primeira linha de cada DTI_ALOC",
        "ORDER BY CPF_DI",
        "",
        "-- (249496 linhas afetadas)",
        "",
        "----------------------------------------------------------- COMPARAÇÃO COM CTG -----------------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #CPF_CTG",
        "SELECT DISTINCT",
        "    CPF        ",
        "INTO #CPF_CTG",
        "FROM CTG${1:0526}",
        "",
        "-- (235315 linhas afetadas)",
        "",
        "DROP TABLE IF EXISTS #CPF_FUNC",
        "SELECT DISTINCT",
        "    CPF        ",
        "INTO #CPF_FUNC",
        "FROM #ROWNUMB",
        "",
        "-- (241209 linhas afetadas)",
        "",
        "DROP TABLE IF EXISTS #NAO_FUNCIONAL",
        "SELECT",
        "     CPF",
        "INTO #NAO_FUNCIONAL",
        "FROM #CPF_CTG A",
        "WHERE NOT EXISTS (  -- ou NOT EXISTS",
        "SELECT",
        "     CPF",
        "FROM #CPF_FUNC B",
        "WHERE A.CPF = B.CPF)",
        "",
        "-- (0 linhas afetadas)",
        "",
        "DROP TABLE IF EXISTS #NAO_CTG",
        "SELECT",
        "     CPF",
        "INTO #NAO_CTG",
        "FROM #CPF_FUNC A",
        "WHERE NOT EXISTS (  -- ou NOT EXISTS",
        "SELECT",
        "     CPF",
        "FROM #CPF_CTG B",
        "WHERE A.CPF = B.CPF)",
        "",
        "-- (5894 linhas afetadas)",
        "",
        "-- CONFERIR SE MOTINTERRUP É 253 OU 290",
        "SELECT TOP 10 *          ",
        "FROM #ROWNUMB",
        "WHERE CPF IN (",
        "    SELECT *          ",
        "    FROM #NAO_CTG",
        ")",
        "",
        "----------------------------------------------------------- CRIAR [00_FUNCIONAL] -----------------------------------------------------------",
        "",
        "ALTER TABLE #ROWNUMB",
        "DROP COLUMN RANK_CPF_DI",
        "",
        "DROP TABLE IF EXISTS [dbo].[00_FUNCIONAL${1:0526}]",
        "SELECT *",
        "INTO [00_FUNCIONAL${1:0526}]",
        "FROM #ROWNUMB"
    ],
    "description": "00_FUNCIONAL_CRIAR"
},

