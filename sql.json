        "    CASE",
        "       WHEN A.SITUACAO_ALOC = 'A' THEN 'A - ATIVO'",
        "       WHEN A.SITUACAO_ALOC = 'E' THEN 'E - ESTÁVEL'",
        "       WHEN A.SITUACAO_ALOC = 'I' THEN 'I - INATIVO'",
        "       ELSE A.SITUACAO_ALOC",
        "    END AS SITUACAO_ALOC ,",
        "    CASE",
        "       WHEN A.VINCULO_ALOC = 'C' THEN 'C - COMISSIONADO'",
        "       WHEN A.VINCULO_ALOC = 'D' THEN 'D - DESIGNADO'",
        "       WHEN A.VINCULO_ALOC = 'T' THEN 'T - TITULAR'",
        "       ELSE A.VINCULO_ALOC",
        "    END AS VINCULO_ALOC ,",
        "    A.CD_CLASSE_DISC_TIT AS CLDISC,    ",
        "    Y.NOME_DISCIPLINA AS CLDISC_DESC ,",
        "    A.CD_IDENT_REF_FAIXA_TIT AS FAIXA,",
        "    A.CD_IDENT_GRAU_NIV_TIT AS GRAU_NIV,",
        "COALESCE(",
        "      CASE",
        "         WHEN A.CD_JORNADA_TIT = 'A' THEN 'A - AMPLIADA (32)'",
        "         WHEN A.CD_JORNADA_TIT = 'B' THEN 'B - BÁSICA (25)'",
        "         WHEN A.CD_JORNADA_TIT = 'C' THEN 'C - COMPLETA (20)'",
        "         WHEN A.CD_JORNADA_TIT = 'L' THEN 'L - COMPLETA (20) - NOVA CARREIRA'",
        "         WHEN A.CD_JORNADA_TIT = 'I' THEN 'I - INTEGRAL (33)'",
        "         WHEN A.CD_JORNADA_TIT = 'R' THEN 'R - REDUZIDA (10)'",
        "         ELSE A.CD_JORNADA_TIT",
        "      END,",
        "      ''",
        "       ) AS JORNADA ,",
        "    A.CD_BANCO_TITUL AS BANCO,",
        "    A.CD_AGEN_TITUL AS AGENCIA,",
        "    A.TP_CONTA_TITUL AS TIPO_CONTA_BANCO,",
        "    A.NR_CONTA_TITUL AS CONTA_BANCO,",
        "    A.CD_VERIF_CONT_TITUL AS COD_VERIF_BANCO,",
