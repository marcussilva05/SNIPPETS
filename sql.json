  "CRIAR_TABELA": {
    "scope": "sql",
    "prefix": "ZCRIARTAB",
    "body": [
      "DROP TABLE IF EXISTS ${1:BASE}",
      "CREATE TABLE ${1:BASE} (",
      "    ${2:COLUNA1} VARCHAR(${3:100}),",
      "    ${4:COLUNA2} VARCHAR(${5:100})",
      ")",
      " ",
      "INSERT INTO ${1:BASE} (${2:COLUNA1}, ${4:COLUNA2}) VALUES", 
      "('${6:DADO}', '${7:DADO}'),",   
      "('${8:DADO}', '${9:DADO}'),",   
      "('${10:DADO}', '${11:DADO}')", 
      ],
    "description": "CRIAR_TABELA"
  },

