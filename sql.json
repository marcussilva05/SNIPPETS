        "-- (315076 linhas afetadas)",
        "",
        "------------------------------------------------------- #ROWFUNC --------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #ROWFUNC;",
        "WITH BASE_RANK1 AS (",
        "   SELECT *",
        "   FROM #COMPLETA_NOME",
        "),",
        "RANK1 AS (",
        "   SELECT *,",
        "      ROW_NUMBER() OVER (PARTITION BY CPF_DI ORDER BY (SELECT NULL)) AS ROW1",
        "   FROM BASE_RANK1",
        ")",
        "SELECT *",
        "INTO #ROWFUNC",
        "FROM RANK1",
        "WHERE ROW1 = 1",
        "ORDER BY CPF_DI",
        "",
