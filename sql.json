        "    A.DTF_INTERRUP_COMIS,",
        "    A.MOTIAFAS_COMIS,",
        "    A.MOTIAFAS_COMIS_DESC,",
        "    A.DTI_MOTIAFAS_COMIS,",
        "    A.DTF_MOTIAFAS_COMIS,",
        "    A.MOTILICE_COMIS,",
        "    A.MOTILICE_COMIS_DESC,",
        "    A.DTI_MOTILICE_COMIS,",
        "    A.DTF_MOTILICE_COMIS,",
        "    COALESCE(C.POLO_C, '') AS POLO_DESIGN ,",
        "    COALESCE(C.REGIAO_C, '') AS REGIAO_DESIGN ,",
        "    COALESCE(C.NOMEDE_C, '') AS URE_DESIGN ,",
        "    COALESCE(C.MUNICIPIO_C, '') AS MUNICIPIO_DESIGN ,",
        "    A.UA_C_DESIGN,    ",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.UA_C_DESIGN = '0' THEN ''",
        "           ELSE A.NOMEUA_C_DESIGN",
        "        END,",
        "        ''",
        "    ) AS NOMEUA_C_DESIGN ,",
        "    A.UE_C_DESIGN,",
        "    A.NOMEESC_C_DESIGN,",
        "    A.CARGO_DESIGN,",
        "    A.CARGO_DESIGN_DESC,",
        "    A.DTI_DESIGN,",
        "    A.REF_FAIXA_DESIGN,",
        "    A.NIV_DESIGN,",
        "    A.CD_MOT_SUBST_DESIGN,",
        "    A.CD_MOT_SUBST_DESIGN_DESC,",
        "    A.CD_TIP_INTERRUP_CESS_DESIGN,",
        "    A.CD_MOT_INTERRUP_CESS_DESIGN,",
        "    A.DT_INIC_INTERRUP_CESS_DESIGN,",
        "    A.DT_FIM_INTERRUP_CESS_DESIGN,",
        "    A.CD_MOT_AFAST_DESIGN,",
        "    A.DT_INIC_AFAST_DESIGN,",
        "    A.DT_FIM_AFAST_DESIGN,",
        "    A.CD_MOT_LIC_DESIGN,",
        "    A.DT_INIC_LIC_DESIGN,",
        "    A.DT_FIM_LIC_DESIGN,",
        "    A.UA_ALOC,    ",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.UA_ALOC = '0' THEN ''",
        "           ELSE E.NOMEUA",
        "        END,",
        "        ''",
        "    ) AS NOMEUA_ALOC ,",
        "    A.CARGO_ALOC, ",
        "    COALESCE(F.NM_CARGO, '') AS CARGO_ALOC_DESC ,",
        "    A.DTI_ALOC, ",
        "    A.DTF_ALOC,",
        "    A.DT_INCLUSAO_ALOC,",
        "    A.SITUACAO_ALOC,",
        "    A.VINCULO_ALOC,",
        "    A.CLDISC,",
        "    A.CLDISC_DESC,",
        "    A.RS,",
        "    A.PV,",
        "    A.RSPV,",
        "    A.FAIXA,",
        "    A.GRAU_NIVEL,",
        "    A.SEXO,",
        "    A.DT_NASCIMENTO,",
        "    A.IDADE,",
        "    COALESCE(",
        "          CASE",
        "             WHEN A.JORNADA = 'A' THEN 'A - AMPLIADA (32)'",
        "             WHEN A.JORNADA = 'B' THEN 'B - BÁSICA (25)'",
        "             WHEN A.JORNADA = 'C' THEN 'C - COMPLETA (20)'",
        "             WHEN A.JORNADA = 'L' THEN 'L - COMPLETA (20) - NOVA CARREIRA'",
        "             WHEN A.JORNADA = 'I' THEN 'I - INTEGRAL (33)'",
        "             WHEN A.JORNADA = 'R' THEN 'R - REDUZIDA (10)'",
        "             ELSE A.JORNADA",
        "          END,",
        "          ''",
        "           ) AS JORNADA ,",
        "    A.TIPO_DEF,",
        "    COALESCE(",
        "          CASE",
        "             WHEN A.COR = 'A' THEN 'A - AMARELO'",
        "             WHEN A.COR = 'B' THEN 'B - BRANCO'",
        "             WHEN A.COR = 'I' THEN 'I - ÍNDIGENA'",
        "             WHEN A.COR = 'N' THEN 'N - NEGRO'",
        "             WHEN A.COR = 'P' THEN 'P - PARDO'",
        "             ELSE A.COR",
        "          END,",
        "          ''",
        "           ) AS COR ,",
        "    A.FORMACAO,",
        "    A.NIVEL_FORMACAO         ",
        "INTO #JOIN3",
        "FROM #JOIN2 A",
        "LEFT JOIN #CGRHANT B ON A.UA_C_COMIS = B.UAC",
        "LEFT JOIN #CGRHANT C ON A.UA_C_DESIGN = C.UAC",
        "LEFT JOIN #ESCOLA D ON A.UA_C_COMIS = D.UA OR A.UA_C_COMIS = D.CODESC",
        "LEFT JOIN #ARQ E ON A.UA_ALOC = E.UA",
        "LEFT JOIN #CARGO F ON A.CARGO_ALOC = F.CD_CARGO",
        "ORDER BY A.REGIAO_C, A.URE_C, A.NOMEUA_C",
