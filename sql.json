        "    FL_TURMA_VINCULO_DIURNO                   ,",
        "    CD_SERIE_TIPO_ENSINO                      ,",
        "    CD_ASPECTO_TURMA_CLASSE                   ,",
        "    CD_TP_DEFICIENCIA",
        "FROM SAS.[${1:03}2026].TB_TURMA",
        "WHERE DT_ANO_LETIVO = 2026 ",
        " AND CD_SITUACAO = 0 ",
        " AND TP_REDE_ENSINO = 1 ",
        " AND QTD_ALUNO_ATIVO > 0",
        " AND CD_DURACAO <> 2 -- Exclusao de Classes de EJA e Itinerario Formativo do 2 Semestre - Verificar sempre no inicio do semestre"
    ],
    "description": "SAS_TB_TURMA"
},

