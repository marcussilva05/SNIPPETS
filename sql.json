// CONTAGEH_00_EVENTO
"CONTAGEH_00_EVENTO": {
    "scope": "sql",
    "prefix": "Z00CONTEVENTO",
    "body": [
        "/*",
        "-------------------------------------------------------------- TEMPORÁRIAS --------------------------------------------------------------",
        "",
        "${1:05}26",
        "[${1:05}2026]",
        "",
        "$2DROP TABLE IF EXISTS #ARQ",
        "DROP TABLE IF EXISTS #ID",
        "DROP TABLE IF EXISTS #PESSOAL",
        "DROP TABLE IF EXISTS #TIP_EVE",
        "DROP TABLE IF EXISTS #CD_EVE",
        "",
        "SELECT * INTO #ARQ FROM ARQDEUA${1:05}26",
        "SELECT * INTO #ID FROM TB_ID_INTERNO_SERV",
        "SELECT * INTO #PESSOAL FROM SAS.[${1:05}2026].TB_PESSOAL",
        "SELECT * INTO #TIP_EVE FROM CONTAGEH.dbo.TB_TIPO_EVENTO",
        "SELECT * INTO #CD_EVE FROM CONTAGEH.dbo.TB_EVENTO",
        "",
        "*/",
        "",
        "/*",
        "",
        "-------------------------------------------------------------- TOP 10 EVENTOS --------------------------------------------------------------",
        "",
        "SELECT TOP 10",
        "    B.REGIAO         ,",
        "    B.NOMEDE AS URE        ,",
        "    A.CD_UNID_ADM_CLASS AS UA_C,",
        "    A.CD_UNID_ADM_EVE,",
        "    B.NOMEUA        ,",
        "    A.NR_CPF AS CPF,",
        "    A.NR_DI AS DI,",
        "    CONCAT(A.NR_CPF, A.NR_DI) AS CPF_DI,",
        "    D.ID             ,",
        "    E.NM_PESSOA AS NOME_SERVIDOR          ,",
