        "",
        "*/",
        "",
        "------------------------------------------------------- #COMPLETA_NOME --------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #COMPLETA_NOME",
        "SELECT",
        "    A.SITUACAO,",
        "    A.ID,",
