  "UNION_SEM_DUPLICATAS": {
    "scope": "sql",
    "prefix": "ZUNION",
    "body": [
	  "${7:DROP TABLE IF EXISTS ${1:#BASE}_UNION}",
      "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
	  "INTO ${1:#BASE}_UNION",
	  "FROM ${5:#BASE1}",
	  "UNION",
	  "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
	  "FROM ${6:#BASE2} -- SE QUISER, COPIE MAIS UM 'UNION ATÉ FROM'" 
    ],
    "description": "UNION_SEM_DUPLICATAS"
  },

