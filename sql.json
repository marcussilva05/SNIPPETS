      "102 = yyyy.mm.dd",
      "103 = dd/mm/yyyy",
      "104 = dd.mm.yyyy",
      "105 = dd-mm-yyyy",
      "120 = yyyy-mm-dd hh:mi:ss",
      "126 = yyyy-mm-ddThh:mi:ss.mmm ",
			"/*"
		],
		"description": "COLA_DATA"
	},
	
	//CONVERTER_TIPO_DE_DADOS
	"CONVERTER_TIPO_DE_DADOS": {
		"scope": "sql",
		"prefix": "ZDDCONVERT",
		"body": [
			"CONVERT(${1:BIGINT}, A.${2:CPF}) AS ${2:CPF}   "
		],
		"description": "CONVERTER_TIPO_DE_DADOS"
	},
	
	//IF
	"IF": {
		"scope": "sql",
		"prefix": "ZIF",
		"body": [
			"IIF(${1:COLUNA}>1, 'YES', 'NO') -- =, <>, !=, >, <"
		],
		"description": "IF"
	},

	// CASE_WHEN
  "CASE_WHEN": {
    "scope": "sql",
    "prefix": "ZCASE",
    "body": [
      "CASE",
      "   WHEN ${1:SITUACAO1} THEN ${2:SITUACAO2}",
      "   ${3:WHEN ${4:SITUACAO1} THEN ${5:SITUACAO2}}",
      "   ELSE ${6:SITUACAO3}",
      "END AS ${7:COLUNA}"
    ],
    "description": "CASE_WHEN"
  },

  // JOIN
  "JOIN": {
    "scope": "sql",
    "prefix": "ZJOIN",
    "body": [
      "${1:LEFT} JOIN ${2:Tabela} ${3:B} ON ${4:A}.${5:coluna} = ${6:B}.${7:coluna}"
    ],
    "description": "JOIN"
  },

  // TRATAMENTO_DE_DADOS
  "TRATAMENTO_DE_DADOS": {
    "scope": "sql",
    "prefix": "ZDDTRAT",
    "body": [
	  "${1:CASE}",
	  "      WHEN ${2:COLUNA} ${3:IS NOT NULL} THEN REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(NOMEUA_COMPLETO, 'Á', 'A'), 'Ã', 'A'), 'À', 'A'), 'Â', 'A'), 'É', 'E'), 'Ê', 'E'), 'Ó', 'O'), 'Õ', 'O'), 'Ú', 'U'), 'Ü', 'U'), 'Ç', 'C'), 'Ñ', 'N')",
	  "     ${1:ELSE COLUNA}",
	  "${1:END AS COLUNA}"
    ],
    "description": "TRATAR DADOS RETIRANDO CARACTERES ESPECÍFICOS"
  },

  // COMPARAR_DADOS_DE_TABELAS_DIFERENTES
  "COMPARAR_DADOS_DE_TABELAS_DIFERENTES": {
    "scope": "sql",
    "prefix": "ZDDCOMPTABLE",
    "body": [
	  "SELECT",
      "     CPF",
	  "FROM #BASE1 A",
	  "WHERE EXISTS (  -- ou NOT EXISTS",
	  "SELECT",
      "     CPF",
	  "FROM #BASE2 B",
	  "WHERE A.CPF = B.CPF)"
    ],
    "description": "COMPARAR_DADOS_DE_TABELAS_DIFERENTES"
  },

  // INSERIR_DADOS_EM_TEMPORARIA
  "INSERIR_DADOS_EM_TEMPORARIA": {
    "scope": "sql",
    "prefix": "ZDDINSTEMP",
    "body": [
	  "DROP TABLE IF EXISTS #${1:BASE_TEMP}",
    "CREATE TABLE #${1:BASE_TEMP} (",
	  "    ${2:COLUNA} ${3:VARCHAR}(${4:100})",
    "    )",
	  "INSERT INTO #${1:BASE_TEMP} (${2:COLUNA}) VALUES",
	  "${5:('DADO1'),}",
    "${5:('DADO2'),}",
	  "${5:('ETC...'),}"
    ],
    "description": "INSERIR_DADOS_EM_TEMPORARIA"
  },

	// UNION_SEM_DUPLICATAS
  "UNION_SEM_DUPLICATAS": {
    "scope": "sql",
    "prefix": "ZUNION",
    "body": [
	  "${7:DROP TABLE IF EXISTS ${1:#BASE}_UNION}",
      "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
	  "INTO ${1:#BASE}_UNION",
	  "FROM ${5:#BASE1}",
	  "UNION",
	  "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
	  "FROM ${6:#BASE2} -- SE QUISER, COPIE MAIS UM 'UNION ATÉ FROM'" 
    ],
    "description": "UNION_SEM_DUPLICATAS"
  },

	// UNION_ALL_MANTEM_DUPLICATAS
  "UNION_ALL_MANTEM_DUPLICATAS": {
    "scope": "sql",
    "prefix": "ZUNIONALL",
    "body": [
	  "${7:DROP TABLE IF EXISTS ${1:#BASE__UNIDA_ALL}}",
      "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
	  "INTO ${1:#BASE__UNIDA_ALL}",
	  "FROM ${5:#BASE1}",
	  "UNION ALL",
	  "SELECT",
	  "${2:COLUNA1}",
	  "${3:COLUNA2}",
	  "${4:COLUNA2}",
	  "FROM ${6:#BASE2} -- SE QUISER, COPIE MAIS UM 'UNION ATÉ FROM'" 
    ],
    "description": "UNION_ALL_MANTEM_DUPLICATAS"
  },

