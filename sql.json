        "      CD_UNID_ESC_EXER_COMIS AS UE_E_COMIS,",
        "      CD_UNID_ADM_EXER_COMIS AS UA_E_COMIS,",
        "      CD_TIP_INTERRUP_CESS_COMIS AS INTERRUP_COMIS,",
        "      CD_MOT_INTERRUP_CESS_COMIS AS MOT_INTERRUP_COMIS,",
        "      DT_INIC_INTERRUP_CESS_COMIS AS DTI_INTERRUP_COMIS,",
        "      DT_FIM_INTERRUP_CESS_COMIS AS DTF_INTERRUP_COMIS,",
        "      CD_MOT_AFAST_COMIS AS MOTIAFAS_COMIS,",
        "      DT_INIC_MOT_AFAST_COMIS AS DTI_MOTIAFAS_COMIS,",
        "      DT_FIM_MOT_AFAST_COMIS AS DTF_MOTIAFAS_COMIS,",
        "      CD_MOT_LIC_COMIS AS MOTILICE_COMIS,",
        "      DT_INIC_LIC_COMIS AS DTI_MOTILICE_COMIS,",
        "      DT_FIM_LIC_COMIS AS DTF_MOTILICE_COMIS,",
        "      CD_CARGO_FUNCAO_DESIGN AS CARGO_DESIGN,",
        "      DT_INIC_DESIGN              ,",
        "      CD_IDENT_REF_FAIXA_DESIGN AS REF_FAIXA_DESIGN,",
        "      CD_IDENT_GRAU_NIV_DESIGN AS NIV_DESIGN,",
        "      CD_UNID_ESC_CLASS_DESIGN AS UE_C_DESIGN,",
        "      CD_UNID_ADM_CLASS_DESIGN AS UA_C_DESIGN,",
        "      CD_MOT_SUBST_DESIGN         ,",
        "      CD_TIP_INTERRUP_CESS_DESIGN ,",
        "      CD_MOT_INTERRUP_CESS_DESIGN ,",
        "      DT_INIC_INTERRUP_CESS_DESIGN,",
        "      DT_FIM_INTERRUP_CESS_DESIGN ,",
        "      CD_MOT_AFAST_DESIGN         ,",
        "      DT_INIC_AFAST_DESIGN        ,",
        "      DT_FIM_AFAST_DESIGN         ,",
        "      CD_MOT_LIC_DESIGN           ,",
