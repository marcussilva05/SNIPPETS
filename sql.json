  // JORNADA_DESC_CASE
  "JORNADA_DESC_CASE": {
      "scope": "sql",
      "prefix": "ZJOR",
      "body": [
          "COALESCE(",
          "      CASE",
          "         WHEN ${1:COLUNA} = 'A' THEN 'A - AMPLIADA (32)'",
          "         WHEN ${1:COLUNA} = 'B' THEN 'B - BÁSICA (25)'",
          "         WHEN ${1:COLUNA} = 'C' THEN 'C - COMPLETA (20)'",
          "         WHEN ${1:COLUNA} = 'L' THEN 'L - COMPLETA (20) - NOVA CARREIRA'",
          "         WHEN ${1:COLUNA} = 'I' THEN 'I - INTEGRAL (33)'",
          "         WHEN ${1:COLUNA} = 'R' THEN 'R - REDUZIDA (10)'",
          "         ELSE ${1:COLUNA}",
          "      END,",
          "      ''",
          "       ) AS ${2:NOME_COLUNA} ,"
      ],
      "description": "JORNADAS A, B, C, L, I, R"
  },

    // COR_DESC_CASE
  "COR_DESC_CASE": {
      "scope": "sql",
      "prefix": "ZCOR",
      "body": [
          "COALESCE(",
          "      CASE",
          "         WHEN ${1:COLUNA} = 'A' THEN 'A - AMARELO'",
          "         WHEN ${1:COLUNA} = 'B' THEN 'B - BRANCO'",
          "         WHEN ${1:COLUNA} = 'I' THEN 'I - ÍNDIGENA'",
          "         WHEN ${1:COLUNA} = 'N' THEN 'N - NEGRO'",
          "         WHEN ${1:COLUNA} = 'P' THEN 'P - PARDO'",
          "         ELSE ${1:COLUNA}",
          "      END,",
          "      ''",
          "       ) AS ${2:NOME_COLUNA} ,"
      ],
      "description": "COR A, B, I, N, P"
  },

