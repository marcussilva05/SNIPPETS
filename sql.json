        "    R.NOMEUA AS NOMEUE_C_DESIGN,",
        "    A.CD_CARGO_FUNCAO_DESIGN AS CARGO_DESIGN,",
        "    S.NM_CARGO AS CARGO_DESIGN_DESC ,",
        "    A.DT_INIC_DESIGN AS DTI_DESIGN,",
        "    A.CD_MOT_SUBST_DESIGN AS MOT_SUBST_DESIGN,",
        "    Z.[COD-EVENTO] AS MOT_SUBST_DESIGN_DESC ,",
        "    A.CD_MOT_INTERRUP_CESS_DESIGN AS MOTINTERRUP_DESIGN,",
        "    T.[COD-EVENTO] AS MOTINTERRUP_DESIGN_DESC ,",
        "    A.DT_INIC_INTERRUP_CESS_DESIGN AS DTI_MOTINTERRUP_DESIGN,",
