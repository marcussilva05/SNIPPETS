        "    A.DT_INIC_AFAST_TIT AS DTI_MOTIAFAS,",
        "    A.DT_FIM_AFAST_TIT AS DTF_MOTIAFAS,",
        "    A.CD_MOT_LIC_TIT AS MOTILICE,",
        "    I.[COD-EVENTO] AS MOTILICE_DESC ,",
        "    A.DT_INIC_LIC_TIT AS DTI_MOTILICE,",
        "    A.DT_FIM_LIC_TIT AS DTF_MOTILICE,",
