  "ALTERAR_TIPO_DADOS_COLUNA": {
    "scope": "sql",
    "prefix": "ZDDALTERTIPO",
    "body": [
      "ALTER TABLE ${1:tabela}",    
      "${6:ALTER COLUMN ${2:coluna1} ${3:TIPO}(${4:tamanho}) NULL ${5:-- VERIFICAR ZCOLA}}"
      ],
