        "    A.DI,",
        "    CONCAT(A.CPF,A.DI) AS CPF_DI ,",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.NOME = '' THEN B.NOME_SERVIDOR",
        "           ELSE A.NOME",
        "        END,",
        "        ''",
        "    ) AS NOME ,",
        "    A.POLO_C,",
