        "WHERE CD_SIT_REG = 'A' -- A = ATIVO, E = EXCLUÍDO , F = falecido, 0 = erro, P CATEGORIA P, I = INATIVO, B = BLOQUEADO"
    ],
    "description": "SAS_TB_FUNCIONAL"
},

// SAS_EDUCA_PESSOAL
"SAS_EDUCA_PESSOAL": {
    "scope": "sql",
    "prefix": "ZSASEDUCAPES",
    "body": [
        "DROP TABLE IF EXISTS #CPFPESSOAL",
        "SELECT",
        "   NOME,",
        "   RS,",
        "   PV,",
        "   CONCAT(RS, PV) AS RSPV,",
        "   DTNASC AS NASCIMENTO,",
        "   CPF,",
        "   CPFDV AS DV,",
        "   RIGHT(CPF, 9) AS CPF_9",
        "INTO #CPFPESSOAL",
        "FROM SAS.[${1:03}2026].EDUCA_PESSOAL",
        "DROP TABLE IF EXISTS #CPF_COMPL",
        "SELECT",
        "   NOME,",
        "   RS,",
        "   PV,",
        "   RSPV,",
        "   NASCIMENTO,",
        "   CPF,",
        "   DV,",
        "   CPF_9,",        
        "   CONCAT(CPF_9, DV) AS CPF_DV",
        "INTO #CPF_COMPL",
        "FROM #CPFPESSOAL",
        "SELECT *",
        "FROM #CPF_COMPL",
        "ORDER BY CPF_DV"
    ],
    "description": "SAS_EDUCA_PESSOAL"
},

