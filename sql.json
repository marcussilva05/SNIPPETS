// SIC_2026060314500161
"SIC_2026060314500161": {
    "scope": "sql",
    "prefix": "ZSIC",
     "body": [
        "/*",
        "",
        "COD - EVENTO",
        "395 - EXONERAÇÃO - EFP",
        "396 - DEMISSÃO - EFP",
        "400 - DEMISSãO INCENTIVADA - PDI",
        "",
        "ANO 20${1:21}",
        "",
        "*/",
        "",
         "USE CEPEA_SAS",
        "",
        "SELECT DISTINCT",
        "     COUNT(*) AS POSSE_20${1:21}",
        "FROM SAS.[052026].TB_FUNCIONAL",
        "-- WHERE CD_SIT_REG = 'A' -- A = ATIVO, E = EXCLUÍDO , F = falecido, 0 = erro, P CATEGORIA P, I = INATIVO, B = BLOQUEADO",
        "WHERE DT_POSSE_TIT BETWEEN '20${1:21}-01-01' AND '20${1:21}-12-31'",
        "",
        "SELECT DISTINCT",
        "      CASE",
        "         WHEN CD_MOT_INTERRUP_CESS_TIT = '395' THEN '395 - EXONERAÇÃO EFP'",
        "         WHEN CD_MOT_INTERRUP_CESS_TIT = '396' THEN '396 - DEMISSÃO - EFP'",
        "         WHEN CD_MOT_INTERRUP_CESS_TIT = '400' THEN '400 - DEMISSãO INCENTIVADA - PDI'",
        "         ELSE CD_MOT_INTERRUP_CESS_TIT",
        "      END AS INTERRUPCAO ,",
        "      COUNT(CD_MOT_INTERRUP_CESS_TIT) AS TOTAL,",
        "      SUM(COUNT(*)) OVER() AS TOTAL_GERAL",
        "FROM SAS.[052026].TB_FUNCIONAL",
        "-- WHERE CD_SIT_REG = 'A' -- A = ATIVO, E = EXCLUÍDO , F = falecido, 0 = erro, P CATEGORIA P, I = INATIVO, B = BLOQUEADO",
        "WHERE (",
        "     DT_INIC_INTERRUP_CESS_TIT BETWEEN '20${1:21}-01-01' AND '20${1:21}-12-31'",
        "     OR DT_INIC_AFAST_TIT BETWEEN '20${1:21}-01-01' AND '20${1:21}-12-31'",
        "     OR DT_INIC_LIC_TIT BETWEEN '20${1:21}-01-01' AND '20${1:21}-12-31'",
        ")",
        "AND (",
        "     CD_MOT_INTERRUP_CESS_TIT IN ('395', '396', '400')",
        "     OR CD_MOT_AFAST_TIT IN ('395', '396', '400')",
        "     OR CD_MOT_LIC_TIT IN ('395', '396', '400')",
        ")",
        "GROUP BY CD_MOT_INTERRUP_CESS_TIT",
        "ORDER BY TOTAL DESC"
    ],
    "description": "SIC_2026060314500161"
}

