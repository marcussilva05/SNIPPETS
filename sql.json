        "    V.[COD-EVENTO] AS MOTILICE_DESIGN_DESC ,",
        "    A.DT_INIC_LIC_DESIGN AS DTI_MOTILICE_DESIGN,",
        "    A.DT_FIM_LIC_DESIGN AS DTF_MOTILICE_DESIGN,",
