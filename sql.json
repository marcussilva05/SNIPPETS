  // EAT1_CRIAR
  "EAT1_CRIAR": {
      "scope": "powershell",
      "prefix": "Z00EAT1_CRIAR",
      "body": [
          "# ============================================================",
          "# SCRIPT COMPLETO - VARREDURA RECURSIVA DE TODA A PASTA CEPEA",
          "# GERA CSV COM METADADOS DE TODOS OS ARQUIVOS",
          "# COPIE E COLE ESTE CÓDIGO EM UM POWERSHELL COMUM (NÃO PODE ABRIR COMO ADMIN)",
          "# ============================================================",
          "",
          "$pasta_origem = \"Z:\\DEPLAN_CEPEA\\CEPEA\"",
          "$pasta_destino = \"C:\\Users\\marcus.silva05\\Downloads\"",
          "$nome_arquivo = \"MAPEAMENTO_CEPEA_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv\"",
          "$caminho_completo = \"$pasta_destino\\$nome_arquivo\"",
          "$arquivo_log_erros = \"$pasta_destino\\erros_varredura_$(Get-Date -Format 'yyyyMMdd_HHmmss').log\"",
          "",
          "Write-Host \"╔════════════════════════════════════════════════════════════╗\" -ForegroundColor Magenta",
          "Write-Host \"║     MAPEAMENTO COMPLETO - PASTA CEPEA                      ║\" -ForegroundColor Magenta",
          "Write-Host \"╚════════════════════════════════════════════════════════════╝\" -ForegroundColor Magenta",
          "Write-Host \"\"",
          "Write-Host \"📂 Pasta de origem: $pasta_origem\" -ForegroundColor Gray",
          "Write-Host \"📁 Pasta de destino: $pasta_destino\" -ForegroundColor Gray",
          "Write-Host \"\"",
          "",
          "# Verificar se a pasta de origem existe",
          "if (-not (Test-Path $pasta_origem)) {",
          "    Write-Host \"❌ ERRO: Pasta de origem não encontrada!\" -ForegroundColor Red",
          "    break",
          "}",
          "",
          "# Criar pasta destino se não existir (Downloads geralmente existe, mas garantia)",
          "if (-not (Test-Path $pasta_destino)) {",
          "    New-Item -ItemType Directory -Path $pasta_destino -Force | Out-Null",
          "}",
          "",
          "Write-Host \"⏳ Iniciando varredura recursiva completa...\" -ForegroundColor Cyan",
          "Write-Host \"   Isso pode levar vários minutos. Pressione Ctrl+C para interromper.\" -ForegroundColor Gray",
          "Write-Host \"\"",
          "",
          "$contador = 0",
          "$contador_erros = 0",
          "$tempo_inicio = Get-Date",
          "$ultima_atualizacao = Get-Date",
          "$arquivos_por_segundo = 0",
          "$arquivos_no_ultimo_segundo = 0",
          "$resultados = @()",
          "",
          "try {",
          "    Get-ChildItem -Path $pasta_origem -File -Recurse -ErrorAction Stop | ForEach-Object {",
          "        $contador++",
          "        ",
          "        # Calcula taxa de processamento a cada segundo",
          "        $agora = Get-Date",
          "        $diferenca = $agora - $ultima_atualizacao",
          "        if ($diferenca.TotalSeconds -ge 1) {",
          "            $arquivos_por_segundo = [math]::Round(($contador - $arquivos_no_ultimo_segundo) / $diferenca.TotalSeconds, 0)",
          "            $arquivos_no_ultimo_segundo = $contador",
          "            $ultima_atualizacao = $agora",
          "        }",
          "        ",
          "        # Exibe progresso",
          "        if ($contador -gt 100 -and $arquivos_por_segundo -gt 0) {",
          "            $tempo_passado = (Get-Date) - $tempo_inicio",
          "            $minutos_passados = [math]::Round($tempo_passado.TotalMinutes, 1)",
          "            Write-Host \"`r📊 Processados: $contador arquivos | Taxa: $arquivos_por_segundo arq/s | Tempo: $minutos_passados min | Erros: $contador_erros\" -NoNewline -ForegroundColor Yellow",
          "        } else {",
          "            Write-Host \"`r📊 Processados: $contador arquivos... | Erros: $contador_erros\" -NoNewline -ForegroundColor Yellow",
          "        }",
          "        ",
          "        try {",
          "            $penult_pasta = if ($_.Directory.Parent) { $_.Directory.Parent.Name } else { \"\" }",
          "            ",
          "            $objeto = [PSCustomObject]@{",
          "                ANO_ULT_ALTERACAO = $_.LastWriteTime.Year   # Nome alterado conforme solicitado",
          "                DT                = $_.LastWriteTime.ToString('yyyy/MM/dd HH:mm')",
          "                NOME_ARQ          = $_.BaseName",
          "                EXTENSAO_ARQ      = $_.Extension.TrimStart('.')",
          "                ULT_PASTA         = $_.Directory.Name",
          "                PENULT_PASTA      = $penult_pasta",
          "                END_COMPLETO      = $_.DirectoryName   # Apenas o caminho da pasta, sem o arquivo",
          "            }",
          "            $resultados += $objeto",
          "        }",
          "        catch {",
          "            $contador_erros++",
          "            \"$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') - ERRO: $($_.FullName) - $($_.Exception.Message)\" | Out-File -FilePath $arquivo_log_erros -Append",
          "        }",
          "        ",
          "        # Checkpoint a cada 5000 arquivos para liberar memória",
          "        if ($contador % 5000 -eq 0) {",
          "            $resultados | Export-Csv -Path \"$caminho_completo.temp\" -Encoding UTF8 -NoTypeInformation -Append",
          "            $resultados = @()",
          "            Write-Host \"`n💾 Checkpoint: $contador arquivos salvos parcialmente\" -ForegroundColor Green",
          "        }",
          "    }",
          "}",
          "catch {",
          "    Write-Host \"`n⚠️ ERRO GLOBAL: $($_.Exception.Message)\" -ForegroundColor Red",
          "    \"$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') - ERRO GLOBAL: $($_.Exception.Message)\" | Out-File -FilePath $arquivo_log_erros -Append",
          "}",
          "",
          "# Salvar o restante",
          "if ($resultados.Count -gt 0) {",
          "    $resultados | Export-Csv -Path \"$caminho_completo.temp\" -Encoding UTF8 -NoTypeInformation -Append",
          "}",
          "",
          "# Mover arquivo temporário para o definitivo",
          "if (Test-Path \"$caminho_completo.temp\") {",
          "    Move-Item -Path \"$caminho_completo.temp\" -Destination $caminho_completo -Force",
          "}",
          "",
          "$tempo_total = (Get-Date) - $tempo_inicio",
          "$minutos_total = [math]::Round($tempo_total.TotalMinutes, 1)",
          "$segundos_total = [math]::Round($tempo_total.TotalSeconds, 0)",
          "",
          "Write-Host \"`n\"",
          "Write-Host \"╔════════════════════════════════════════════════════════════╗\" -ForegroundColor Green",
          "Write-Host \"║     ✅ MAPEAMENTO CONCLUÍDO!                               ║\" -ForegroundColor Green",
          "Write-Host \"╚════════════════════════════════════════════════════════════╝\" -ForegroundColor Green",
          "Write-Host \"\"",
          "Write-Host \"📁 Arquivo gerado: $caminho_completo\" -ForegroundColor Cyan",
          "Write-Host \"📊 Total de arquivos processados: $contador\" -ForegroundColor Cyan",
          "Write-Host \"⚠️  Erros ignorados: $contador_erros\" -ForegroundColor Yellow",
          "Write-Host \"📝 Log de erros: $arquivo_log_erros\" -ForegroundColor Yellow",
          "Write-Host \"⏱️  Tempo total: $minutos_total minutos ($segundos_total segundos)\" -ForegroundColor Cyan",
          "Write-Host \"⚡ Taxa média: $([math]::Round($contador / $tempo_total.TotalSeconds, 0)) arq/s\" -ForegroundColor Cyan",
          "Write-Host \"\"",
          "",
          "# Pergunta final",
          "$abrir_pasta = Read-Host \"Deseja abrir a pasta Downloads? (S/N)\"",
          "if ($abrir_pasta -eq \"S\" -or $abrir_pasta -eq \"s\") {",
          "    explorer $pasta_destino",
          "}"
      ],
      "description": "Varredura recursiva da pasta CEPEA gerando CSV com metadados"
  },

// 00_EAT1_CONSULTA
"00_EAT1_CONSULTA": {
    "scope": "sql",
    "prefix": "Z00EAT1_CONSULTA",
    "body": [
        "SELECT     ",
        "ANO_ULT_ALTERACAO  ,",
        "DT,",
        "PENULT_PASTA,",
        "ULT_PASTA,",
        "NOME_ARQ,",
        "EXTENSAO_ARQ,",
        "END_COMPLETO",
        "FROM [00_EAT1]",
        "${1:WHERE ${2:END_COMPLETO} LIKE '%${3:PESQUISA}%'}",
        "ORDER BY DT DESC"
    ],
    "description": "00_EAT1_CONSULTA"
  },

// CRIAR_00_MAP
"CRIAR_00_MAP": {
    "scope": "sql",
    "prefix": "ZMAP_CRIAR",
    "body": [
        "IF OBJECT_ID('TEMPDB..#MAPEAMENTO') IS NOT NULL",
        "    DROP TABLE #MAPEAMENTO",
        "",
        "CREATE TABLE #MAPEAMENTO (",
        "    ANO_TABELA int NULL,",
        "    ANO_ULT_ALTERACAO int NULL,        ",
        "    BD sysname NULL,",
        "    ESQUEMA sysname NULL,              ",
        "    TABELA sysname NULL,",
        "    COLUNA sysname NULL,",
        "    NUM_COLUNAS int NULL,              ",
        "    NUM_LINHAS bigint NULL,            ",
        "    END_COMPLETO varchar(500) NULL",
        ")",
        "",
        "EXEC sp_MSforeachdb '",
        "USE [?]",
        "",
        "INSERT INTO #MAPEAMENTO (",
        "    ANO_TABELA,",
        "    ANO_ULT_ALTERACAO,",
        "    BD,",
        "    ESQUEMA,",
        "    TABELA,",
        "    COLUNA,",
        "    NUM_COLUNAS,",
        "    NUM_LINHAS,",
        "    END_COMPLETO",
        ")",
        "SELECT",
        "    YEAR(A.create_date) AS ANO_TABELA,",
        "    YEAR(A.modify_date) AS ANO_ULT_ALTERACAO,",
        "    DB_NAME() AS BD,",
        "    SCHEMA_NAME(A.schema_id) AS ESQUEMA,",
        "    A.name AS TABELA,",
        "    B.name AS COLUNA,",
        "    (SELECT COUNT(*) FROM sys.columns C WHERE C.object_id = A.object_id) AS NUM_COLUNAS,",
        "    (SELECT SUM(part.rows)",
        "     FROM sys.partitions part",
        "     WHERE part.object_id = A.object_id",
        "       AND part.index_id IN (0,1)) AS NUM_LINHAS,",
        "    -- ========== LINHA MODIFICADA ==========",
        "    -- ANTIGO: caminho com coluna",
        "    -- NOVO: comando SELECT TOP 10",
        "    ''SELECT TOP 10 * FROM '' + DB_NAME() + ''.'' + SCHEMA_NAME(A.schema_id) + ''.'' + A.name AS END_COMPLETO",
        "    -- ======================================",
        "FROM sys.tables A",
        "INNER JOIN sys.columns B ON A.object_id = B.object_id",
        "WHERE A.is_ms_shipped = 0",
        "'"
    ],
    "description": "CRIAR_00_MAP"
},

  // 00_MAP_SELECT
  "00_MAP_SELECT": {
      "scope": "sql",
      "prefix": "ZMAP_CONSULTA",
      "body": [
          "$4SELECT DISTINCT",
          "    ANO_TABELA,",
          "    ANO_ULT_ALTERACAO,",
          "    BD,",
          "    ESQUEMA,",
          "    TABELA,",
          "    ${1:--}COLUNA,",
          "    NUM_COLUNAS,",
          "    NUM_LINHAS,",
          "    END_COMPLETO",
          "FROM [00_MAP]",
          "${2:--} WHERE END_COMPLETO LIKE '%${3:PESQUISA}%' ${1:,--} OR COLUNA LIKE '%${3:PESQUISA}%'",
          "ORDER BY ANO_TABELA DESC, BD, ESQUEMA, TABELA DESC ${1:--}, COLUNA"
      ],
      "description": "00_MAP_SELECT"
  },

    // CRIAR E-MAIL DE ESCOLA
  "CRIAR_E-MAIL_ESCOLA": {
    "scope": "sql",
    "prefix": "ZEMAIL",
    "body": [
      "${1:CASE                                                              }",
      "   WHEN CATESC='VINCULADA' THEN",
      "      CONCAT('e', FORMAT(ESCVINC, '000000'), 'a@educacao.sp.gov.br')",
      "   ELSE",
      "       CONCAT('e', FORMAT(CODESC, '000000'), 'a@educacao.sp.gov.br')",
      "END",
      "AS EMAIL"
    ],
    "description": "CRIAÇÃO DE E-MAIL DE ESCOLAS"
  },

      // EXTRAIR ZEROS RG 12
  "EXTRAIR_ZEROS_RG_12": {
    "scope": "sql",
    "prefix": "ZDDRG",
    "body": [
      "${1:LEFT(NR_RG, 12) AS RG_TRUNCADO,}"
    ],
    "description": "EXTRAIR ZEROS RG 12"
  },

  // E-MAILS_VAZIOS
  "E-MAILS_VAZIOS": {
    "scope": "sql",
    "prefix": "ZEMAVAZIO",
    "body": [
      "${2:COALESCE(NULLIF(EMAIL_INST2, ''), EMAIL_INST1) AS EMAILI_DIRETOR,}  -- NULLIF converte string vazia para NULL, só assim COALESCE funciona para acrescentar e-mail2 quando email1 for vazio ",
      "${1:-- COALESCE(NULLIF(EMAIL_INST2, ''), NULLIF(EMAIL_INST1, ''), 'SEM_EMAIL') AS EMAIL_DIRETOR -- valor padrão quando ambos forem vazios}"
    ],
    "description": "E-MAILS_VAZIOS"
  },

    // WHERE
  "WHERE": {
    "scope": "sql",
    "prefix": "ZWHERE",
    "body": [
      "${5:WHERE ${1:coluna1} ${2:LIKE} '%${3:DADO}%' ${4:-- LIKE '%%', NOT LIKE '%%', = '', <> '', MAIOR/MENOR/IGUAL, OR, AND, BETWEEN, IN ('','',''), NOT IN('','',''), NULL/NOTNULL}}"    
      ],
    "description": "WHERE"
  },

    // WHERE_DATAS
  "WHERE_DATAS": {
    "scope": "sql",
    "prefix": "ZWHERED",
    "body": [
      "${7:WHERE ${1:coluna1} BETWEEN '%${2:DATA1}%' AND '%${3:DATA2}%' ${6:-- LIKE '%%', NOT LIKE '%%', = '', <> '', MAIOR/MENOR/IGUAL, OR, AND, BETWEEN, IN ('','',''), NOT IN('','',''), NULL/NOTNULL}}",   
      "${4:--YEAR(coluna1) = 2024}", 
      "${5:--MONTH(coluna1) = 01}"
      ],
    "description": "WHERE_DATAS"
  },

    // ROW_NUMBER
  "ROW_NUMBER_SEM_DUPLICATAS": {
    "scope": "sql",
    "prefix": "ZROW",
    "body": [
      "$5WITH BASE_RANK${1:1} AS (",                                                              
      "   --SELECT *",
      "   --FROM BASE",
      "),",
      "RANK${2:1} AS (",
      "   SELECT *,",
      "      ROW_NUMBER() OVER (PARTITION BY ${3:CPF_DI} ORDER BY (SELECT NULL)) AS ROW${4:1} -- OU ORDER BY coluna1 DESC",
      "   FROM BASE_RANK${1:1}",
      ")",
      "SELECT *",
      "FROM RANK${2:1}",
      "WHERE ROW${4:1} = 1 --PRIMEIRA LINHA DA DUPLICATA",  
      "ORDER BY ${3:CPF_DI}"
      ],
    "description": "ROW_NUMBER"
  },

    // ROW_NUMBER_MULTIPLO
  "ROW_NUMBER_MULTIPLO": {
    "scope": "sql",
    "prefix": "ZROWMULT",
    "body": [
      "$6WITH BASE_RANK${1:1} AS (",                                                              
      "   --SELECT *",
      "   --FROM BASE",
      "),",
      "RANK${2:1} AS (",
      "   SELECT *,",
      "      ROW_NUMBER() OVER (PARTITION BY ${3:coluna1} ORDER BY (SELECT NULL)) AS RANK_${3:coluna1}, -- OU ORDER BY ${3:coluna1} DESC",
      "      ROW_NUMBER() OVER (PARTITION BY ${4:coluna2} ORDER BY (SELECT NULL)) AS RANK_${4:coluna2} -- OU ORDER BY ${4:coluna2} DESC",
      "   FROM BASE_RANK${1:1}",
      ")",
      "SELECT *",
      "INTO ${5:BASE_SEM_DUPLICIDADE}",
      "FROM RANK${2:1}",
      "WHERE RANK_${3:coluna1} = 1   -- Primeira linha de cada DADO DA COLUNA ${3:coluna1}",  
      "   OR RANK_${4:coluna2} = 1   -- Primeira linha de cada DADO DA COLUNA ${4:coluna2}", 
      "ORDER BY ${3:CPF_DI}"
      ],
    "description": "FILTRO DUPLO EM LISTA ÚNICA"
  },

  // EXTRAI_TEMPO
  "EXTRAI_TEMPO": {
    "scope": "sql",
    "prefix": "ZDDTEMP",
    "body": [
      "YEAR(A.create_date) AS ANO_TABELA",
      "MONTH(A.create_date) AS MES_TABELA,",
      "DAY(A.create_date) AS DIA_TABELA,",
      "DATEPART(HOUR, A.create_date) AS HORA_TABELA,",
      "DATEPART(MINUTE, A.create_date) AS MINUTO_TABELA,",
      "DATEPART(SECOND, A.create_date) AS SEGUNDOS_TABELA"
      ],
    "description": "EXTRAI REGISTROS DE TEMPOS COMPOSTOS DD/MM/YYYY HH:MM:SS"
  },

  // COLA_DE_DADOS
  "COLA_DE_DADOS": {
    "scope": "sql",
    "prefix": "ZCOLADATA",
    "body": [
      "/*",
      "REGRAS DE BOAS PRÁTICAS:",
      "  - VARCHAR para textos (a menos que precise de Unicode)",
      "  - Tipos numéricos para números (nunca guarde números em VARCHAR)",
      "  - Tipos de data para datas (nunca guarde datas em texto)",
      "  - Evite MAX a menos que necessário (índices não funcionam bem)",
      "",
      "TIPO          |                                        | OCUPAÇÃO       | EXEMPLO DE USO                 | O QUE ARMAZENA",
      "--------------|----------------------------------------|----------------|--------------------------------|-------------------------------",
      "BIT 0 ou 1                                             | 1 byte         | ativo BIT DEFAULT 1            | 1 (verdadeiro), 0 (falso)",
      "TINYINT(0 a 255)                                       | 1 byte         | idade TINYINT                  | 25, 0, 255",
      "INT(-2,1Bi a 2,1Bi)                                    | 4 bytes        | id INT IDENTITY(1,1)           | 1, 999, -4587",
      "DECIMAL(p,s) Até 38 dígitos                            | 5-17 bytes     | salario DECIMAL(10,2)          | 12345.67, -999.99",
      "NUMERIC(p,s) Mesmo que DECIMAL                         | 5-17 bytes     | nota NUMERIC(4,2)              | 9.75, 7.50",
      "MONEY(-922 tri a 922 tri)                              | 8 bytes        | salario MONEY                  | 5250.75, 125000.00",
      "FLOAT(-1.79E+308 a 1.79E+308)                          | 4 ou 8 bytes   | temperatura FLOAT              | 23.56789, -15.3",
      "CHAR(1 a 8000) Fixo, n = 1-8000                        | n bytes        | uf CHAR(2)                     | 'SP', 'RJ', 'MG'",
      "VARCHAR(1-8000) Variável, n = 1-8000                   | tam + 2 bytes  | nome VARCHAR(100)              | 'João Silva', 'Ana'",
      "VARCHAR(MAX) Até 2GB                                   | tam + 2 bytes  | observacao VARCHAR(MAX)        | Textos longos",
      "NCHAR(1 a 4000) Unicode fixo, n = 1-4000               | n * 2 bytes    | nome_japones NCHAR(50)         | '田中太郎'",
      "NVARCHAR(1-4000) Unicode var, n = 1-4000               | (tam*2)+2 bytes| nome_completo NVARCHAR(100)    | 'João', '张伟', '😊'",
      "NVARCHAR(MAX) Unicode até 2GB                          | (tam*2)+2 bytes| comentario NVARCHAR(MAX)       | Textos c/ emojis",
      "TEXT Obsoleto (use VARCHAR(MAX))                       | Variável       | descricao TEXT (evitar)        | 'Texto antigo...'",
      "NTEXT Obsoleto (use NVARCHAR(MAX))                     | Variável       | descricao NTEXT (evitar)       | 'Texto unicode antigo'",
      "DATE do tipo 0001-01-01 a 9999-12-31                   | 3 bytes        | data_nascimento DATE           | '1990-05-15'",
      "TIME(n) do tipo 00:00:00 a 23:59:59.9999999            | 3-5 bytes      | hora_entrada TIME              | '14:30:00'",
      "DATETIME do tipo 1753-01-01 a 9999-12-31               | 8 bytes        | data_cadastro DATETIME         | '2024-03-19 15:45:30'",
      "*/"
    ],
    "description": "Cola de tipos de dados SQL Server"
  },

  // ID_PRIMRIRA_VEZ
  "ID_PRIMRIRA_VEZ": {
    "scope": "sql",
    "prefix": "ZID",
    "body": [
      "${1:ID INT IDENTITY(1,1) PRIMARY KEY}"    
      ],
    "description": "ID_PRIMRIRA_VEZ"
  },

  // ID_ACRESCENTADO_EM_COLUNA
  "ID_ACRESCENTADO_EM_COLUNA": {
    "scope": "sql",
    "prefix": "ZID+",
    "body": [
      "ALTER TABLE ${1:tabela}",
      "ADD ID INT IDENTITY(1,1) PRIMARY KEY",
    ],
    "description": "ACRESCENTA COLUNA ID COM PRIMARY KEY (direto)"
  },

  // CRIAR_TABELA
  "CRIAR_TABELA": {
    "scope": "sql",
    "prefix": "ZCRIARTAB",
    "body": [
      "$12DROP TABLE IF EXISTS ${1:BASE}",
      "CREATE TABLE ${1:BASE} (",
      "    ${2:COLUNA1} VARCHAR(${3:100}),",
      "    ${4:COLUNA2} VARCHAR(${5:100})",
      ")",
      " ",
      "INSERT INTO ${1:BASE} (${2:COLUNA1}, ${4:COLUNA2}) VALUES", 
      "('${6:DADO}', '${7:DADO}'),",   
      "('${8:DADO}', '${9:DADO}'),",   
      "('${10:DADO}', '${11:DADO}')", 
      ],
    "description": "CRIAR_TABELA"
  },

  // CRIAR_COLUNA
  "CRIAR_COLUNA": {
    "scope": "sql",
    "prefix": "ZCRIARCOL",
    "body": [
      "ALTER TABLE ${1:nome_da_tabela}",
      "    ADD  ${2:coluna1} NVARCHAR(${3:100}) NULL,",
      "    ADD  ${4:coluna1} NVARCHAR(${5:100}) NULL"   
      ],
    "description": "CRIAR_COLUNA"
  },
  
  // DROP_TABLE
  "DROP_TABLE": {
    "scope": "sql",
    "prefix": "ZDROP",
    "body": [
      "${2:DROP TABLE IF EXISTS ${1:#BASE}}",
      ],
    "description": "DROP TABLE IF EXISTS"
  },

    // EXCLUIR_COLUNA
  "EXCLUIR_COLUNA": {
    "scope": "sql",
    "prefix": "ZEXCLCOL",
    "body": [
      "ALTER TABLE ${1:tabela}",
      "DROP COLUMN ${2:coluna1}, ${3:coluna2}"   
      ],
    "description": "EXCLUIR_COLUNA"
  },
  // EXCLUIR_LINHAS_NULL
  "EXCLUIR_LINHAS_NULL": {
    "scope": "sql",
    "prefix": "ZEXCLLINULL",
    "body": [
      "DELETE FROM ${1:tabela}",
      "WHERE ${2:coluna1} IS NULL",
      "   AND ${3:coluna2} IS NULL",  
      "   AND ${4:coluna3} IS NULL", 
      ],
    "description": "EXCLUIR_LINHAS_NULL"
  },

  // COUNT
  "COUNT": {
    "scope": "sql",
    "prefix": "ZCOUNT",
    "body": [
      "COUNT(${1:CPF+DI}) AS ${2:TOTAL} ${3:-- SUM(* OU COLUNA), AVG(* OU COLUNA), MAX(* OU COLUNA), MIN(* OU COLUNA) VEJA MAIS EM ZGROUP}",  
      ],
    "description": "CONTAR E AGRUPAR"
  },	

  // GROUP_BY
  "GROUP_BY": {
      "scope": "sql",
      "prefix": "ZGROUP",
      "body": [        
      "$3GROUP BY ${1:COLUNA1}",
      "${2:ORDER BY TOTAL DESC}"
      ],
      "description": "GROUP_BY"
  },

  // HAVING
  "HAVING": {
      "scope": "sql",
      "prefix": "ZCOUNTHAVING",
      "body": [
      "HAVING ${1:COUNT(*) > 10 } -- FILTRAR APÓS O GROUP BY COM COUNT",
      "   ${2:AND AVG(preco) > 50}",
      "${3:ORDER BY TOTAL DESC}"
      ],
      "description": "HAVING = FILTRAR APÓS O GROUP BY"
  },

  // NULL
  "NULL": {
      "scope": "sql",
      "prefix": "ZNULL",
      "body": [
      "ISNULL(${1:COLUNA},'') AS ${2:NOVO_NOME1},"
