        "    A.CD_MOT_LIC_DESIGN,",
        "    A.DT_INIC_LIC_DESIGN,",
        "    A.DT_FIM_LIC_DESIGN,",
        "    A.UA_ALOC,",
        "    A.NOMEUA_ALOC,",
        "    A.CARGO_ALOC,",
        "    A.CARGO_ALOC_DESC,",
        "    A.DTI_ALOC,",
        "    A.DTF_ALOC,",
        "    A.DT_INCLUSAO_ALOC,",
        "    A.SITUACAO_ALOC,",
        "    A.VINCULO_ALOC,",
        "    A.CLDISC,",
        "    A.CLDISC_DESC,",
        "    A.RS,",
