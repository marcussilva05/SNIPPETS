		"prefix": "ZDDLIMP1",
		"body": [
			"${1:LTRIM}${2:RTRIM}(${3:COLUNA}) AS LIMPA_${4:ESQUERDA}${5:DIREITA}"
		],
		"description": "LIMPAR_ESPACOS_VAZIOS_DA_ESQUERDA_OU_DIREITA"
