  // EXECUTE_BD
  "EXECUTE_BD": {
    "scope": "sql",
    "prefix": "ZSYSBDEXEC",
    "body": [
      "$2EXEC sp_helpdb '${1:nome_do_banco}'"    
      ],
    "description": "EXECUTE_BD"
  },

  // LISTAR_TEBELAS
  "LISTAR_TEBELAS": {
    "scope": "sql",
    "prefix": "ZSYSTABLIST",
    "body": [  
      "$1SELECT", 
      "t.name AS NOME_TABELA,",
      "SCHEMA_NAME(t.schema_id) AS ESQUEMA,",
      "YEAR(t.create_date) AS ANO_CRIACAO,",
      "YEAR(t.modify_date) AS ANO_MODIFICACAO,",
      "(SELECT COUNT(*) FROM sys.columns c WHERE c.object_id = t.object_id) AS QTD_COLUNAS,",
      "SUM(p.rows) AS QTD_LINHAS_APROX",
      "FROM sys.tables t",
      "LEFT JOIN sys.partitions p ON t.object_id = p.object_id",
      "GROUP BY ",
      "    t.name,",
      "    t.schema_id,",
      "    t.create_date,",
      "    t.modify_date,",
      "    t.object_id ",
      "ORDER BY ",
      "    ANO_MODIFICACAO DESC"      
      ],
    "description": "LISTAR TEBELAS"
  },

  // DADOS_DA_TABELA
  "DADOS_DA_TABELA": {
      "scope": "sql",
      "prefix": "ZSYSDDTAB",
      "body": [
          "EXEC sp_help '${1:NOME_TABELA}'"
      ],
      "description": "Retorna informações da tabela (colunas, índices, constraints) via sp_help"
  },

  // COLUNAS_NA_VERTICAL_CEPEA_SAS
  "COLUNAS_NA_VERTICAL_CEPEA_SAS": {
    "scope": "sql",
    "prefix": "ZSYSCOLVCEPEA",
    "body": [
      "$4SELECT                                    ",    
      "COLUMN_NAME AS COLUNA",
      "FROM INFORMATION_SCHEMA.COLUMNS",
      "WHERE TABLE_SCHEMA = '${1:dbo}'      ${3:-- schema separado sem colchetes [dbo] = dbo}",
      "  AND TABLE_NAME = 'CTG${2:02}26'  ${3:-- nome da tabela sem colchetes}",
      "ORDER BY ORDINAL_POSITION"
      ],
    "description": "TERMINAL COM COLUNAS_NA_VERTICAL_CEPEA_SAS"
  },

  // COLUNAS_NA_VERTICAL_SAS
  "COLUNAS_NA_VERTICAL_SAS": {
    "scope": "sql",
    "prefix": "ZSYSCOLVSAS",
    "body": [
      "${5:USE ${1:SAS}                                    }",
      "SELECT",    
      "   COLUMN_NAME AS COLUNA",
      "FROM INFORMATION_SCHEMA.COLUMNS",
      "WHERE TABLE_SCHEMA = '${2:02}2026' ${4:-- schema separado sem colchetes [022026] = 022026}",
      "  AND TABLE_NAME = '${3:pap_ua}'  ${4:-- nome da tabela sem colchetes}",
      "ORDER BY ORDINAL_POSITION"
      ],
    "description": "TERMINAL COM COLUNAS_NA_VERTICAL_SAS"
  },

  // LISTAR_INSTANCIAS_SQL_SERVER
"LISTAR_INSTANCIAS_SQL_SERVER": {
    "scope": "sql",
    "prefix": "ZSYSINST",
    "body": [
        "DECLARE @GetInstances TABLE (Value nvarchar(100), InstanceNames nvarchar(100), Data nvarchar(100));",
        "INSERT INTO @GetInstances",
        "EXECUTE xp_regread",
        "    @rootkey = 'HKEY_LOCAL_MACHINE',",
        "    @key = 'SOFTWARE\\Microsoft\\Microsoft SQL Server',",
        "    @value_name = 'InstalledInstances'",
        "SELECT InstanceNames FROM @GetInstances"
    ],
    "description": "LISTAR INSTANCIAS SQL SERVER INSTALADAS"
  },

