        "INTO #JOIN2",
        "FROM #JOIN1 A",
        "LEFT JOIN [00_CATEG] B ON A.CATEG_C = B.CATEG",
        "LEFT JOIN [00_QUADRO] C ON A.QUADRO_C = C.QUADRO",
        "LEFT JOIN #ARQ D ON A.CD_UNID_ESC_EXERC_TIT = D.UA",
        "LEFT JOIN [00_CATEG] E ON A.CATEG_E = E.CATEG",
        "LEFT JOIN [00_QUADRO] F ON A.QUADRO_E = F.QUADRO",
        "LEFT JOIN #BFE G ON A.CD_MOT_INTERRUP_CESS_TIT = G.COD",
        "LEFT JOIN #BFE H ON A.CD_MOT_AFAST_TIT = H.COD",
        "LEFT JOIN #BFE I ON A.CD_MOT_LIC_TIT = I.COD",
        "LEFT JOIN #ARQ J ON A.CD_UNID_ADM_CLASS_COMIS = J.UA",
        "LEFT JOIN #CARGO K ON A.CD_CARGO_FUNCAO_COMIS = K.CD_CARGO",
        "LEFT JOIN [00_CATEG] L ON A.CD_IDENT_CAT_FUNC_COMIS = L.CATEG",
        "LEFT JOIN #ARQ M ON A.CD_UNID_ADM_EXER_COMIS = M.UA",
        "LEFT JOIN #BFE N ON A.CD_MOT_INTERRUP_CESS_COMIS = N.COD",
        "LEFT JOIN #BFE O ON A.CD_MOT_AFAST_COMIS = O.COD",
        "LEFT JOIN #BFE P ON A.CD_MOT_LIC_COMIS = P.COD",
        "LEFT JOIN #ARQ Q ON A.CD_UNID_ADM_CLASS_DESIGN = Q.UA",
        "LEFT JOIN #ARQ R ON A.CD_UNID_ESC_CLASS_DESIGN = R.UA",
        "LEFT JOIN #CARGO S ON A.CD_CARGO_FUNCAO_DESIGN = S.CD_CARGO",
        "LEFT JOIN #BFE T ON A.CD_MOT_INTERRUP_CESS_COMIS = T.COD",
        "LEFT JOIN #BFE U ON A.CD_MOT_AFAST_COMIS = U.COD",
        "LEFT JOIN #BFE V ON A.CD_MOT_LIC_COMIS = V.COD",
        "LEFT JOIN #ARQ W ON A.UA_ALOC = W.UA",
        "LEFT JOIN #CARGO X ON A.CARGO_ALOC = X.CD_CARGO",
        "LEFT JOIN #DISC Y ON A.CD_CLASSE_DISC_TIT = CONVERT(VARCHAR(100), Y.COD_DISCIPLINA)",
        "LEFT JOIN #BFE Z ON A.CD_MOT_SUBST_DESIGN = Z.COD",
        "",
        "-- (310405 linhas afetadas)",
        "",
        "----------------------------------------------------------- #JOIN3 -----------------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #JOIN3",
        "SELECT",
        "    COALESCE(A.SITUACAO, '') AS SITUACAO,",
        "    COALESCE(A.CD_VINC_SIT, '') AS CD_VINC_SIT,",
        "    COALESCE(A.ID, '0') AS ID, ",
        "    -- A.ID_INTERNO, ",
        "    COALESCE(A.CPF, '0') AS CPF,",
        "    COALESCE(A.DI, '0') AS DI,",
        "    COALESCE(A.CPF_DI, '0') AS CPF_DI,",
        "    COALESCE(A.NOME_SERVIDOR, '') AS NOME_SERVIDOR,",
        "    COALESCE(A.POLO_C, '') AS POLO_C,",
        "    COALESCE(A.REGIAO_C, '') AS REGIAO_C,",
        "    COALESCE(A.URE_C, '') AS URE_C,",
        "    COALESCE(A.UA_C, '0') AS UA_C,",
        "    COALESCE(A.NOMEUA_C, '') AS NOMEUA_C,",
        "    COALESCE(A.MUNICIPIO_C, '') AS MUNICIPIO_C,",
        "    COALESCE(A.COD_CARGO_C, '0') AS COD_CARGO_C,",
        "    COALESCE(A.CARGO_C, '') AS CARGO_C,",
        "    COALESCE(A.CATEG_C, '') AS CATEG_C,",
        "    COALESCE(A.CATEGORIA_C, '') AS CATEGORIA_C,",
        "    COALESCE(A.QUADRO_C, '') AS QUADRO_C,",
        "    COALESCE(A.DTI_EXERC_CLASS, '') AS DTI_EXERC_CLASS,",
        "    COALESCE(A.ANOS_TRAB_CARGO_C, '0') AS ANOS_TRAB_CARGO_C,",
        "    COALESCE(A.POLO_E, '') AS POLO_E,",
        "    COALESCE(A.REGIAO_E, '') AS REGIAO_E,",
        "    COALESCE(A.URE_E, '') AS URE_E,",
        "    COALESCE(A.UA_E, '0') AS UA_E,",
        "    COALESCE(A.NOMEUA_E, '') AS NOMEUA_E,",
        "    COALESCE(A.LOCAL_UA_E, '') AS LOCAL_UA_E,",
        "    COALESCE(A.MUNICIPIO_E, '') AS MUNICIPIO_E,",
        "    COALESCE(A.CARGO_E, '0') AS CARGO_E,",
        "    COALESCE(A.NOME_CARGO_E, '') AS NOME_CARGO_E,",
        "    COALESCE(A.CATEG_E, '') AS CATEG_E,",
        "    COALESCE(A.CATEGORIA_E, '') AS CATEGORIA_E,",
        "    COALESCE(A.QUADRO_E, '') AS QUADRO_E,",
        "    COALESCE(A.DTI_EXERC_E, '') AS DTI_EXERC_E,",
        "    COALESCE(A.MOTINTERRUP, '0') AS MOTINTERRUP,",
        "    COALESCE(A.MOTINTERRUP_DESC, '') AS MOTINTERRUP_DESC,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTI_INTERRUP = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTI_INTERRUP), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTI_INTERRUP,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTF_INTERRUP = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTF_INTERRUP), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTF_INTERRUP,",
        "    COALESCE(A.MOTIAFAS, '0') AS MOTIAFAS,",
        "    COALESCE(A.MOTIAFAS_DESC, '') AS MOTIAFAS_DESC,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTI_MOTIAFAS = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTI_MOTIAFAS), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTI_MOTIAFAS,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTF_MOTIAFAS = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTF_MOTIAFAS), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTF_MOTIAFAS,    ",
        "    COALESCE(A.MOTILICE, '0') AS MOTILICE,",
        "    COALESCE(A.MOTILICE_DESC, '') AS MOTILICE_DESC,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTI_MOTILICE = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTI_MOTILICE), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTI_MOTILICE,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTF_MOTILICE = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTF_MOTILICE), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTF_MOTILICE, ",
        "    COALESCE(A.UA_C_COMIS, '0') AS UA_C_COMIS,",
        "    CASE ",
        "        WHEN A.UA_C_COMIS = 0 THEN ''",
        "        ELSE A.NOMEUA_C_COMIS",
        "    END AS NOMEUA_C_COMIS,",
        "    COALESCE(A.CARGO_COMIS, '0') AS CARGO_COMIS,",
        "    COALESCE(A.CARGO_COMIS_DESC, '') AS CARGO_COMIS_DESC,",
        "    COALESCE(A.CATEG_COMIS, '') AS CATEG_COMIS,",
        "    COALESCE(A.CATEG_DESC_COMIS, '') AS CATEG_DESC_COMIS,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTI_COMIS = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTI_COMIS), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTI_COMIS, ",
        "    COALESCE(A.UA_E_COMIS, '0') AS UA_E_COMIS,",
        "    CASE ",
        "        WHEN A.UA_E_COMIS = 0 THEN ''  ",
        "        ELSE A.NOMEUA_E_COMIS",
        "    END AS NOMEUA_E_COMIS,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DTI_E_COMIS = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DTI_E_COMIS), 105)",
        "    END, ",
        "    ''",
        "    ) AS DTI_E_COMIS, ",
        "    COALESCE(A.VINC_COMIS, '') AS VINC_COMIS,",
        "    COALESCE(",
        "    CASE ",
        "        WHEN A.DT_VINC_COMIS = '1900-01-01' THEN ''",
        "        ELSE CONVERT(VARCHAR(10), CONVERT(DATE, A.DT_VINC_COMIS), 105)",
        "    END, ",
        "    ''",
        "    ) AS DT_VINC_COMIS, ",
