        "      CD_UNID_ADM_EXER_COMIS AS UA_E_COMIS,",
        "      CD_TIP_INTERRUP_CESS_COMIS AS INTERRUP_COMIS,",
        "      CD_MOT_INTERRUP_CESS_COMIS AS MOT_INTERRUP_COMIS,",
        "      DT_INIC_INTERRUP_CESS_COMIS AS DTI_INTERRUP_COMIS,",
        "      DT_FIM_INTERRUP_CESS_COMIS AS DTF_INTERRUP_COMIS,",
        "      CD_MOT_AFAST_COMIS AS MOTIAFAS_COMIS,",
        "      DT_INIC_MOT_AFAST_COMIS AS DTI_MOTIAFAS_COMIS,",
        "      DT_FIM_MOT_AFAST_COMIS AS DTF_MOTIAFAS_COMIS,",
