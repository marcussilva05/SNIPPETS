	},

  //SOMAR_DATA
  "SOMAR_DATA": {
      "scope": "sql",
      "prefix": "ZDTSOMAR",
      "body": [
          "${1:DATEADD(${3:YEAR, MONTH, DAY}, ${4:QTD}, TRY_CAST(${5:COLUNA} AS DATE)) AS ${6:NOVO_NOME} -- SOMA DATA + QTD}"
      ],
      "description": "SOMAR DATA OU CALCULAR DIFERENÇA"
  }, 

  //SUBTRAIR_DATA
	"SUBTRAIR_DATA": {
		"scope": "sql",
		"prefix": "ZDTSUBTRAIR",
		"body": [
			"DATEDIFF(${1:YEAR, MONTH, DAY}, TRY_CAST(${2:COLUNA1} AS DATE), TRY_CAST(${3:COLUNA2} AS DATE)) AS ${4:NOVA_COLUNA}"
		],
		"description": "SUBTRAIR_DATA"
	},

	//CONVERTER_DATA
	"CONVERTER_DATA": {
		"scope": "sql",
		"prefix": "ZDTCONVERT",
		"body": [
			"CONVERT(VARCHAR(10), TRY_CAST(${1:COLUNA} AS DATE), ${2:103}) -- 101 = mm/dd/yyyy; 102 = yyyy.mm.dd; 103 = dd/mm/yyyy; 104 = dd.mm.yyyy; 105 = dd-mm-yyyy; 120 = yyyy-mm-dd hh:mi:ss; 126 = yyyy-mm-ddThh:mi:ss.mmm ",
		],
		"description": "CONVERTER_DATA"
	},

