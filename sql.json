  // LISTAR_TEBELAS
  "LISTAR_TEBELAS": {
    "scope": "sql",
    "prefix": "ZSYSTABLIST",
    "body": [  
      "SELECT", 
      "t.name AS NOME_TABELA,",
      "SCHEMA_NAME(t.schema_id) AS ESQUEMA,",
      "YEAR(t.create_date) AS ANO_CRIACAO,",
      "YEAR(t.modify_date) AS ANO_MODIFICACAO,",
      "(SELECT COUNT(*) FROM sys.columns c WHERE c.object_id = t.object_id) AS QTD_COLUNAS,",
      "SUM(p.rows) AS QTD_LINHAS_APROX",
      "FROM sys.tables t",
      "LEFT JOIN sys.partitions p ON t.object_id = p.object_id",
      "GROUP BY ",
      "    t.name,",
      "    t.schema_id,",
      "    t.create_date,",
      "    t.modify_date,",
      "    t.object_id ",
      "ORDER BY ",
      "    QTD_LINHAS_APROX DESC"      
      ],
    "description": "LISTAR TEBELAS"
  },

  // COLUNAS_NA_VERTICAL_CEPEA_SAS
  "COLUNAS_NA_VERTICAL_CEPEA_SAS": {
    "scope": "sql",
    "prefix": "ZSYSCOLVCEPEA",
    "body": [
      "${4:SELECT                                    }",    
      "COLUMN_NAME AS COLUNA",
      "FROM INFORMATION_SCHEMA.COLUMNS",
      "WHERE TABLE_SCHEMA = '${1:dbo}'      ${3:-- schema separado sem colchetes [dbo] = dbo}",
      "  AND TABLE_NAME = 'CTG${2:02}26'  ${3:-- nome da tabela sem colchetes}",
      "ORDER BY ORDINAL_POSITION"
      ],
    "description": "TERMINAL COM COLUNAS_NA_VERTICAL_CEPEA_SAS"
  },

