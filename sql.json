        "      DT_INIC_INTERRUP_CESS_TIT AS DTI_INTERRUP,",
        "      DT_FIM_INTERRUP_CESS_TIT AS DTF_INTERRUP,",
        "      CD_MOT_AFAST_TIT AS MOTIAFAS,",
        "      DT_INIC_AFAST_TIT AS DTI_MOTIAFAS,",
        "      DT_FIM_AFAST_TIT AS DTF_MOTIAFAS,",
