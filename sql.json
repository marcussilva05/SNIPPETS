// 00_FUNCIONAL_CRIAR
"00_FUNCIONAL_CRIAR": {
    "scope": "sql",
    "prefix": "Z00FUNC_CRIAR",
    "body": [
        "/*",
        "${1:0426}",
        "${2:0326} -- MES ANTERIOR",
        "[${3:042026}]",
        "*/",
        "",
        "USE CEPEA_SAS",
        "",
        "---------------------------------------------------------------------------------------------------- TEMPORÁRIAS --------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #CGRH",
        "DROP TABLE IF EXISTS #CGRHANT",
        "DROP TABLE IF EXISTS #FUNC",
        "DROP TABLE IF EXISTS #ID",
        "DROP TABLE IF EXISTS #CPF_COMPL",
        "DROP TABLE IF EXISTS #CPFP",
        "DROP TABLE IF EXISTS #ALOC",
        "DROP TABLE IF EXISTS #ALOC_ROW",
        "DROP TABLE IF EXISTS #NIVEL",
        "DROP TABLE IF EXISTS #ESCOLA",
        "DROP TABLE IF EXISTS #ARQ",
        "DROP TABLE IF EXISTS #CARGO",
        "DROP TABLE IF EXISTS #DISC",
        "DROP TABLE IF EXISTS #00UA",
        "DROP TABLE IF EXISTS #PESSOAL",
        "DROP TABLE IF EXISTS #CPFPESSOAL",
        "DROP TABLE IF EXISTS #CHOR",
        "DROP TABLE IF EXISTS #BFE",
        "",
        "SELECT * INTO #CGRH FROM CGRH_APOIO.DBO.BASE_SERVIDORES_ATIVOS_FINAL_${1:0426}",
        "SELECT * INTO #CGRHANT FROM CGRH_APOIO.DBO.BASE_SERVIDORES_ATIVOS_FINAL_${2:0326}",
        "SELECT * INTO #FUNC FROM SAS.[${3:042026}].TB_FUNCIONAL",
        "SELECT * INTO #ID FROM TB_ID_INTERNO_SERV",
        "SELECT * INTO #ALOC FROM SAS.[${3:042026}].[TB_UA_ALOCACAO]",
        "SELECT * INTO #NIVEL FROM NIVEL_FORMACAO${1:0426}",
        "SELECT * INTO #ESCOLA FROM ESCOLAS${1:0426}",
        "SELECT * INTO #ARQ FROM ARQDEUA${1:0426}",
        "SELECT * INTO #CARGO FROM TAB_CARGO${1:0426}",
        "SELECT * INTO #DISC FROM DESENV.DBO.DISCIPLINA",
        "SELECT * INTO #00UA FROM [00_UA]",
        "SELECT * INTO #PESSOAL FROM SAS.[${3:042026}].EDUCA_PESSOAL",
        "SELECT * INTO #CHOR FROM CHOR${1:0426}",
        "SELECT * INTO #BFE FROM TAB_CODBFE",
        "",
        "SELECT",
        "   CPF,",
        "   CPFDV AS DI,",
        "   RIGHT(CPF, 9) AS CPF_9,",
        "   NOME,",
        "   RS,",
        "   PV,",
        "   CONCAT(RS, PV) AS RSPV,",
        "   DTNASC AS NASCIMENTO",
        "INTO #CPFPESSOAL",
        "FROM SAS.[${3:042026}].EDUCA_PESSOAL",
        "SELECT",
        "   NOME,",
        "   RS,",
        "   PV,",
        "   RSPV,",
        "   NASCIMENTO,",
        "   CPF,",
        "   DI,",
        "   CPF_9,",
        "   CONCAT(CPF_9, DI) AS CPF_DI",
        "INTO #CPF_COMPL",
        "FROM #CPFPESSOAL",
        "",
        "----------------------------------------------------------------------------------- TEMP ALOC -------------------------------------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #ALOC",
        "SELECT",
        "    NR_CPF             ,",
        "    NR_DI              ,",
        "    CONCAT(NR_CPF, NR_DI) AS CPF_DI,",
        "    CD_UA              ,",
        "    CD_CARGO           ,",
        "    FL_RESPONSAVEL     ,",
        "    DT_INI_VIG         ,",
        "    DT_FIM_VIG         ,",
        "    ID_USU_EXCLUSAO    ,",
        "    DT_EXCLUSAO        ,",
        "    ID_USU_INCLUSAO    ,",
        "    DT_INCLUSAO        ,",
        "    DT_CARGA           ,",
        "    ID_USU_ALTERACAO   ,",
        "    DT_ALTERACAO       ,",
        "    FL_SITUACAO        , -- A (EFETIVO) E (ESTÁVEIS) I (INATIVOS)",
        "    DS_OBSERVACAO      ,",
        "    updated            ,",
        "    fl_alter           ,",
        "    CD_IDENT_SIT_VINC  , -- C (COMISSIONADOS) D (DESIGNADOS) T (TITULARES)",
        "    ID_PCNP            ,",
        "    COD_DISCIPLINA_PCNP",
        "INTO #ALOC",
        "FROM SAS.[${3:042026}].[TB_UA_ALOCACAO]",
        "",
        "----------------------------------------------------------------------------------- TEMP ROW -------------------------------------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #ALOC_ROW;",
        "WITH RANK_CPF_DI AS (",
        "    SELECT",
        "        *,",
        "        ROW_NUMBER() OVER (",
        "            PARTITION BY CPF_DI               ",
        "            ORDER BY DT_INCLUSAO DESC   ",
        "        ) AS RN",
        "    FROM #ALOC",
        ")",
        "SELECT *",
        "INTO #ALOC_ROW",
        "FROM RANK_CPF_DI",
        "WHERE RN = 1",
        "",
        "---------------------------------------------------------------------------------------------------- #JOIN1 --------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #JOIN1",
        "SELECT",
        "    COALESCE(C.CD_SIT_REG, '') AS SITUACAO, -- A = ATIVO, E = EXCLUÍDO , F = falecido, 0 = erro, P CATEGORIA P, I = INATIVO, B = BLOQUEADO",
        "    COALESCE(A.ID_INTERNO, B.ID, '0') AS ID,",
        "    COALESCE(B.CPF, C.NR_CPF, '0') AS CPF,",
        "    COALESCE(A.DI, C.NR_DI, '0') AS DI,",
        "    --COALESCE(D.NOME, '') AS NOME,",
        "    COALESCE(A.POLO_C, '') AS POLO_C,",
        "    COALESCE(A.REGIAO_C, '') AS REGIAO_C,",
        "    COALESCE(A.NOMEDE_C, '') AS URE_C,",
        "    COALESCE(A.MUNICIPIO_C, '') AS MUNICIPIO_C,",
        "    COALESCE(A.UAC, C.CD_UNID_ADM_CLASS_TIT, '0') AS UA_C,",
        "    COALESCE(A.NOMEUA_C, '') AS NOMEUA_C,",
        "    COALESCE(C.CD_UNID_ESC_CLASS_TIT, '0') AS UE_C,",
        "    COALESCE(A.CARGO_C, '0') AS CARGO_C,",
        "    COALESCE(A.NOMECAR_C, '') AS NOMECARGO_C,",
        "    COALESCE(A.QUADRO_C, '') AS QUADRO_C,",
        "    COALESCE(A.CATEG_C, C.CD_IDENT_CAT_FUNC_TIT, '') AS CATEG_C,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN A.DT_INICIO_EXERCICIO_C IS NULL OR A.DT_INICIO_EXERCICIO_C = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), A.DT_INICIO_EXERCICIO_C, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_EXERC_C,",
        "    COALESCE(A.ANOS_TRAB_CARGO_C, '0') AS ANOS_TRAB_CARGO_C,",
        "",
        "    COALESCE(A.POLO_E, '') AS POLO_E,",
        "    COALESCE(A.REGIAO_E, '') AS REGIAO_E,",
        "    COALESCE(A.NOMEDE_E, '') AS URE_E,",
        "    COALESCE(A.MUNICIPIO_E, '') AS MUNICIPIO_E,",
        "    COALESCE(A.UA_E, C.CD_UNID_ADM_EXERC_TIT, '0') AS UA_E,",
        "    COALESCE(A.NOMEUA_E, '') AS NOMEUA_E,",
        "    COALESCE(C.CD_UNID_ESC_EXERC_TIT, '0') AS UE_E,",
        "    COALESCE(A.CARGO_E, '0') AS CARGO_E,",
        "    COALESCE(A.NOMECAR_E, '') AS NOMECARGO_E,",
        "    COALESCE(A.QUADRO_E, '') AS QUADRO_E,",
        "    COALESCE(A.CATEG_E, '') AS CATEG_E,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN A.DATA_INICIO_EXERCICIO_E IS NULL OR A.DATA_INICIO_EXERCICIO_E = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), A.DATA_INICIO_EXERCICIO_E, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_EXERC_E,",
        "",
        "    COALESCE(C.CD_IDENT_SIT_ESPEC_TIT, '0') AS SITESP,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_SIT_ESPEC_TIT IS NULL OR C.DT_INIC_SIT_ESPEC_TIT = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_SIT_ESPEC_TIT, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_SITESP,",
        "    COALESCE(C.CD_MOT_INTERRUP_CESS_TIT, '0') AS INTERRUP,",
        "    -- DATA DTI_INTERRUP: adicionado COALESCE",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_INTERRUP_CESS_TIT IS NULL OR C.DT_INIC_INTERRUP_CESS_TIT = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_INTERRUP_CESS_TIT, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_INTERRUP,",
        "    -- DATA DTF_INTERRUP: adicionado COALESCE",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_INTERRUP_CESS_TIT IS NULL OR C.DT_FIM_INTERRUP_CESS_TIT = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_INTERRUP_CESS_TIT, 105)",
        "        END,",
        "        ''",
        "    ) AS DTF_INTERRUP,",
        "    COALESCE(C.CD_MOT_AFAST_TIT, '0') AS MOTIAFAS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_AFAST_TIT IS NULL OR C.DT_INIC_AFAST_TIT = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_AFAST_TIT, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_MOTIAFAS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_AFAST_TIT IS NULL OR C.DT_FIM_AFAST_TIT = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_AFAST_TIT, 105)",
        "        END,",
        "        ''",
        "    ) AS DTF_MOTIAFAS,",
        "    COALESCE(C.CD_MOT_LIC_TIT, '0') AS MOTILICE,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_LIC_TIT IS NULL OR C.DT_INIC_LIC_TIT = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_LIC_TIT, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_MOTILICE,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_LIC_TIT IS NULL OR C.DT_FIM_LIC_TIT = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_LIC_TIT, 105)",
        "        END,",
        "        ''",
        "    ) AS DTF_MOTILICE,",
        "",
        "    COALESCE(C.CD_CARGO_FUNCAO_COMIS, '0') AS CARGO_COMIS,",
        "    COALESCE(C.CD_IDENT_CAT_FUNC_COMIS, '') AS CATEG_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_POSSE_COMIS IS NULL OR C.DT_POSSE_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_POSSE_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_POSSE_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_EXERC_COMIS IS NULL OR C.DT_INIC_EXERC_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_EXERC_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_EXERC_COMIS,",
        "    COALESCE(C.CD_UNID_ESC_CLASS_COMIS, '0') AS UE_C_COMIS,",
        "    COALESCE(C.CD_UNID_ADM_CLASS_COMIS, '0') AS UA_C_COMIS,",
        "    COALESCE(C.CD_UNID_ESC_EXER_COMIS, '0') AS UE_E_COMIS,",
        "    COALESCE(C.CD_UNID_ADM_EXER_COMIS, '0') AS UA_E_COMIS,",
        "    COALESCE(C.CD_MOT_INTERRUP_CESS_COMIS, '0') AS MOT_INTERRUP_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_INTERRUP_CESS_COMIS IS NULL OR C.DT_INIC_INTERRUP_CESS_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_INTERRUP_CESS_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_INTERRUP_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_INTERRUP_CESS_COMIS IS NULL OR C.DT_FIM_INTERRUP_CESS_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_INTERRUP_CESS_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DTF_INTERRUP_COMIS,",
        "    COALESCE(C.CD_MOT_AFAST_COMIS, '0') AS MOTIAFAS_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_MOT_AFAST_COMIS IS NULL OR C.DT_INIC_MOT_AFAST_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_MOT_AFAST_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_MOTIAFAS_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_MOT_AFAST_COMIS IS NULL OR C.DT_FIM_MOT_AFAST_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_MOT_AFAST_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DTF_MOTIAFAS_COMIS,",
        "    COALESCE(C.CD_MOT_LIC_COMIS, '0') AS MOTILICE_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_LIC_COMIS IS NULL OR C.DT_INIC_LIC_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_LIC_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_MOTILICE_COMIS,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_LIC_COMIS IS NULL OR C.DT_FIM_LIC_COMIS = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_LIC_COMIS, 105)",
        "        END,",
        "        ''",
        "    ) AS DTF_MOTILICE_COMIS,",
        "",
        "    COALESCE(C.CD_CARGO_FUNCAO_DESIGN, '0') AS CARGO_DESIGN,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_DESIGN IS NULL OR C.DT_INIC_DESIGN = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_DESIGN, 105)",
        "        END,",
        "        ''",
        "    ) AS DTI_DESIGN,",
        "    COALESCE(C.CD_IDENT_REF_FAIXA_DESIGN, '') AS REF_FAIXA_DESIGN,",
        "    COALESCE(C.CD_IDENT_GRAU_NIV_DESIGN, '') AS NIV_DESIGN,",
        "    COALESCE(C.CD_UNID_ESC_CLASS_DESIGN, '0') AS UE_C_DESIGN,",
        "    COALESCE(C.CD_UNID_ADM_CLASS_DESIGN, '0') AS UA_C_DESIGN,",
        "    COALESCE(C.CD_MOT_SUBST_DESIGN, '0') AS CD_MOT_SUBST_DESIGN,",
        "    COALESCE(C.CD_TIP_INTERRUP_CESS_DESIGN, '0') AS CD_TIP_INTERRUP_CESS_DESIGN,",
        "    COALESCE(C.CD_MOT_INTERRUP_CESS_DESIGN, '0') AS CD_MOT_INTERRUP_CESS_DESIGN,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_INTERRUP_CESS_DESIGN IS NULL OR C.DT_INIC_INTERRUP_CESS_DESIGN = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_INTERRUP_CESS_DESIGN, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_INIC_INTERRUP_CESS_DESIGN,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_INTERRUP_CESS_DESIGN IS NULL OR C.DT_FIM_INTERRUP_CESS_DESIGN = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_INTERRUP_CESS_DESIGN, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_FIM_INTERRUP_CESS_DESIGN,",
        "    COALESCE(C.CD_MOT_AFAST_DESIGN, '0') AS CD_MOT_AFAST_DESIGN,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_AFAST_DESIGN IS NULL OR C.DT_INIC_AFAST_DESIGN = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_AFAST_DESIGN, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_INIC_AFAST_DESIGN,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_AFAST_DESIGN IS NULL OR C.DT_FIM_AFAST_DESIGN = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_AFAST_DESIGN, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_FIM_AFAST_DESIGN,",
        "    COALESCE(C.CD_MOT_LIC_DESIGN, '0') AS CD_MOT_LIC_DESIGN,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_INIC_LIC_DESIGN IS NULL OR C.DT_INIC_LIC_DESIGN = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_INIC_LIC_DESIGN, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_INIC_LIC_DESIGN,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN C.DT_FIM_LIC_DESIGN IS NULL OR C.DT_FIM_LIC_DESIGN = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), C.DT_FIM_LIC_DESIGN, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_FIM_LIC_DESIGN,",
        "",
        "    COALESCE(A.LOCAL_UA, '') AS LOCAL_UA,",
        "    COALESCE(A.DISC_CONCURSO, C.CD_CLASSE_DISC_TIT, '0') AS CLDISC,",
        "    --COALESCE(D.RS ,'') AS RS ,",
        "    --COALESCE(D.PV ,'') AS PV ,",
        "    COALESCE(C.CD_IDENT_REF_FAIXA_TIT, '') AS FAIXA,",
        "    COALESCE(C.CD_IDENT_GRAU_NIV_TIT, '') AS GRAU_NIVEL,",
        "    COALESCE(A.SEXO, '') AS SEXO,",
        "    COALESCE(",
        "        CASE ",
        "            WHEN A.DATA_NASCIMENTO IS NULL OR A.DATA_NASCIMENTO = '1900-01-01' THEN ''",
        "            ELSE CONVERT(VARCHAR(10), A.DATA_NASCIMENTO, 105)",
        "        END,",
        "        ''",
        "    ) AS DT_NASCIMENTO,",
        "    COALESCE(A.IDADE, '0') AS IDADE,",
        "    COALESCE(A.JORNADA, C.CD_JORNADA_TIT, '') AS JORNADA,",
        "    COALESCE(A.TIPO_DEF, '') AS TIPO_DEF,",
        "    COALESCE(A.ID_COR, '') AS COR",
        "INTO #JOIN1",
        "FROM #CGRH A",
        "LEFT JOIN #ID B ON A.ID_INTERNO = B.ID",
        "LEFT JOIN #FUNC C ON B.CPF = C.NR_CPF",
        "",
        "WHERE C.CD_SIT_REG = 'A' -- A = ATIVO, E = EXCLUÍDO , F = falecido, 0 = erro, P CATEGORIA P, I = INATIVO, B = BLOQUEADO",
        "",
        "ORDER BY A.REGIAO_C, A.NOMEDE_C, A.MUNICIPIO_C, A.NOMEUA_C -- D.NOME",
        "",
        "---------------------------------------------------------------------------------------------------- #JOIN2 --------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #JOIN2",
        "SELECT DISTINCT",
        "    CASE",
        "       WHEN A.SITUACAO = 'A' THEN 'ATIVO'",
        "       ELSE A.SITUACAO",
        "    END AS SITUACAO ,",
        "    A.ID,",
        "    COALESCE(A.CPF, B.CPF_DI, C.NR_CPF, D.CPF, '') AS CPF ,",
        "    COALESCE(A.DI, B.DI, C.NR_DI, D.DI, '') AS DI ,",
        "    COALESCE(B.NOME, '') AS NOME ,",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.POLO_C = '' THEN J.POLO_C",
        "           ELSE A.POLO_C",
        "        END,",
        "        ''",
        "     ) AS POLO_C,",
        "    COALESCE(A.REGIAO_C, F.REGIAO, '') AS REGIAO_C ,",
        "    COALESCE(A.URE_C, F.NOMEDE, '') AS URE_C ,",
        "    COALESCE(A.MUNICIPIO_C, F.NOMEMUN, '') AS MUNICIPIO_C ,",
        "    A.UA_C,",
        "    A.NOMEUA_C,",
        "    A.UE_C,",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.UE_C = '0' THEN ''",
        "           ELSE F.NOMEESC",
        "        END, ",
        "        ''",
        "    ) AS NOMEESC_C ,",
        "    A.CARGO_C,",
        "    A.NOMECARGO_C,",
        "    COALESCE( ",
        "        CASE",
        "        WHEN A.QUADRO_C = 'QM' THEN 'QM - QUADRO DO MAGISTÉRIO'",
        "        WHEN A.QUADRO_C = 'QAE' THEN 'QAE - QUADRO DE APOIO A EDUCAÇÃO'",
        "        WHEN A.QUADRO_C = 'QSE' THEN 'QSE - QUADRO DA SECRETARIA DA EDUCAÇÃO'",
        "        ELSE A.QUADRO_C",
        "        END,",
        "        ''",
        "    ) AS QUADRO_C,",
        "    A.CATEG_C,",
        "    I.CATEG_DESC AS CATEG_C_DESC,",
        "    A.DTI_EXERC_C,",
        "    A.ANOS_TRAB_CARGO_C,",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.POLO_E = '' THEN K.POLO_C",
        "           ELSE A.POLO_E",
        "        END,",
        "        ''",
        "     ) AS POLO_E,",
        "    A.REGIAO_E,",
        "    A.URE_E,",
        "    A.MUNICIPIO_E,",
        "    A.UA_E,",
        "    A.NOMEUA_E,     ",
        "    A.UE_E,",
        "    COALESCE(G.NOMEESC, H.NOMEUA, '') AS NOMEESC_E , ----------------------------------------------",
        "    A.CARGO_E,",
        "    A.NOMECARGO_E,",
        "    COALESCE( ",
        "        CASE",
        "        WHEN A.QUADRO_E = 'QM' THEN 'QM - QUADRO DO MAGISTÉRIO'",
        "        WHEN A.QUADRO_E = 'QAE' THEN 'QAE - QUADRO DE APOIO A EDUCAÇÃO'",
        "        WHEN A.QUADRO_E = 'QSE' THEN 'QSE - QUADRO DA SECRETARIA DA EDUCAÇÃO'",
        "        ELSE A.QUADRO_E",
        "        END,",
        "        ''",
        "    ) AS QUADRO_E,",
        "    A.CATEG_E,",
        "    L.CATEG_DESC AS CATEG_E_DESC,",
        "    A.DTI_EXERC_E,",
        "    CASE",
        "       WHEN A.SITESP = 'R' THEN 'R - READAPTADO'",
        "       WHEN A.SITESP = 'A' THEN 'A - ADIDO'",
        "       ELSE A.SITESP",
        "    END AS SITESP ,",
        "    A.DTI_SITESP,",
        "    A.INTERRUP,",
        "    COALESCE(M.[COD-EVENTO], '') AS INTERRUP_DESC,",
        "    A.DTI_INTERRUP,",
        "    A.DTF_INTERRUP,",
        "    A.MOTIAFAS,",
        "    COALESCE(N.[COD-EVENTO], '') AS MOTIAFAS_DESC,",
        "    A.DTI_MOTIAFAS,",
        "    A.DTF_MOTIAFAS,",
        "    A.MOTILICE,",
        "    COALESCE(O.[COD-EVENTO], '') AS MOTILICE_DESC,",
        "    A.DTI_MOTILICE,",
        "    A.DTF_MOTILICE,",
        "    A.CARGO_COMIS,",
        "    COALESCE(T.NM_CARGO, '') AS CARGO_DESC,",
        "    A.CATEG_COMIS,",
        "    COALESCE(U.CATEG_DESC, '') AS CATEG_COMIS_DESC,",
        "    A.DT_POSSE_COMIS,",
        "    A.DTI_EXERC_COMIS,",
        "    A.UA_C_COMIS,",
        "    COALESCE(V.NOMEUA, '') AS NOMEUA_C_COMIS , ----------------------------------------------",
        "    A.UE_C_COMIS,",
        "    COALESCE(W.NOMEESC, '') AS NOMEESC_C_COMIS ,",
        "    A.UA_E_COMIS,",
        "    COALESCE(X.NOMEUA, '') AS NOMEUA_E_COMIS , ----------------------------------------------",
        "    A.UE_E_COMIS,",
        "    COALESCE(Y.NOMEESC, '') AS NOMEESC_E_COMIS ,",
        "    A.MOT_INTERRUP_COMIS,",
        "    COALESCE(P.[COD-EVENTO], '') AS MOT_INTERRUP_COMIS_DESC,",
        "    A.DTI_INTERRUP_COMIS,",
        "    A.DTF_INTERRUP_COMIS,",
        "    A.MOTIAFAS_COMIS,",
        "    COALESCE(Q.[COD-EVENTO], '') AS MOTIAFAS_COMIS_DESC,",
        "    A.DTI_MOTIAFAS_COMIS,",
        "    A.DTF_MOTIAFAS_COMIS,",
        "    A.MOTILICE_COMIS,",
        "    COALESCE(R.[COD-EVENTO], '') AS MOTILICE_COMIS_DESC,",
        "    A.DTI_MOTILICE_COMIS,",
        "    A.DTF_MOTILICE_COMIS,",
        "    A.CARGO_DESIGN,",
        "    COALESCE(Z.NM_CARGO, '') AS CARGO_DESIGN_DESC ,",
        "    A.DTI_DESIGN,",
        "    A.REF_FAIXA_DESIGN,",
        "    A.NIV_DESIGN,",
        "    A.UA_C_DESIGN,",
        "    COALESCE(AA.NOMEUA, '') AS NOMEUA_C_DESIGN , ----------------------------------------------",
        "    A.UE_C_DESIGN,",
        "    COALESCE(AB.NOMEESC, '') AS NOMEESC_C_DESIGN ,",
        "    A.CD_MOT_SUBST_DESIGN,",
        "    COALESCE(S.[COD-EVENTO], '') AS CD_MOT_SUBST_DESIGN_DESC,",
        "    A.CD_TIP_INTERRUP_CESS_DESIGN,",
        "    A.CD_MOT_INTERRUP_CESS_DESIGN,",
        "    A.DT_INIC_INTERRUP_CESS_DESIGN,",
        "    A.DT_FIM_INTERRUP_CESS_DESIGN,",
        "    A.CD_MOT_AFAST_DESIGN,",
        "    A.DT_INIC_AFAST_DESIGN,",
        "    A.DT_FIM_AFAST_DESIGN,",
        "    A.CD_MOT_LIC_DESIGN,",
        "    A.DT_INIC_LIC_DESIGN,",
        "    A.DT_FIM_LIC_DESIGN,",
        "    COALESCE(C.CD_UA, '') AS UA_ALOC              ,       ",
        "    COALESCE(C.CD_CARGO, '') AS CARGO_ALOC              ,    ",
        "    COALESCE(",
        "            CASE ",
        "                WHEN C.DT_INI_VIG IS NULL OR C.DT_INI_VIG = '1900-01-01' THEN ''",
        "                ELSE CONVERT(VARCHAR(10), C.DT_INI_VIG, 105)",
        "            END,",
        "            ''",
        "    ) AS DTI_ALOC,",
        "    COALESCE(",
        "            CASE ",
        "                WHEN C.DT_FIM_VIG IS NULL OR C.DT_FIM_VIG = '1900-01-01' THEN ''",
        "                ELSE CONVERT(VARCHAR(10), C.DT_FIM_VIG, 105)",
        "            END,",
        "            ''",
        "    ) AS DTF_ALOC,",
        "    COALESCE(",
        "            CASE ",
        "                WHEN C.DT_INCLUSAO IS NULL OR C.DT_INCLUSAO = '1900-01-01' THEN ''",
        "                ELSE CONVERT(VARCHAR(10), C.DT_INCLUSAO, 105)",
        "            END,",
        "            ''",
        "    ) AS DT_INCLUSAO_ALOC,",
        "    COALESCE(",
        "        CASE",
        "           WHEN C.FL_SITUACAO = 'A' THEN 'A - EFETIVO'",
        "           WHEN C.FL_SITUACAO = 'E' THEN 'E - ESTÁVEL'",
        "           WHEN C.FL_SITUACAO = 'I' THEN 'E - INATIVO'",
        "           ELSE C.FL_SITUACAO",
        "        END,",
        "        ''",
        "    ) AS SITUACAO_ALOC ,",
        "    COALESCE(",
        "        CASE",
        "           WHEN C.CD_IDENT_SIT_VINC = 'C' THEN 'C - COMISSIONADO'",
        "           WHEN C.CD_IDENT_SIT_VINC = 'D' THEN 'D - DESIGNADO'",
        "           WHEN C.CD_IDENT_SIT_VINC = 'T' THEN 'T - TITULAR'",
        "           ELSE C.CD_IDENT_SIT_VINC",
        "        END,",
        "        ''",
        "    ) AS VINCULO_ALOC ,",
        "    CONVERT(VARCHAR(100), A.CLDISC) AS CLDISC,",
        "    CONVERT(VARCHAR(100), COALESCE(AC.NOME_DISCIPLINA, '')) AS CLDISC_DESC ,",
        "    COALESCE(B.RS, '') AS RS ,",
        "    COALESCE(B.PV, '') AS PV ,",
        "    COALESCE(B.RSPV, '') AS RSPV ,",
        "    A.FAIXA,",
        "    A.GRAU_NIVEL,",
        "    A.SEXO,",
        "    COALESCE(A.DT_NASCIMENTO, B.NASCIMENTO, '') AS DT_NASCIMENTO ,",
        "    A.IDADE,",
        "    A.JORNADA,      ----------------------------------------------",
        "    A.TIPO_DEF,",
        "    A.COR,        ----------------------------------------------",
        "    E.FORMACAO,",
        "    E.NIVEL_FORMACAO",
        "INTO #JOIN2",
        "FROM #JOIN1 A",
        "LEFT JOIN #CPF_COMPL B ON A.CPF = B.CPF_DI",
        "LEFT JOIN #ALOC_ROW C ON A.CPF = C.NR_CPF AND A.DI = C.NR_DI",
        "LEFT JOIN #CHOR D ON A.CPF = D.CPF AND A.DI = D.DI",
        "LEFT JOIN #NIVEL E ON A.CPF = E.CPF AND A.DI = E.DI",
        "LEFT JOIN #ESCOLA F ON A.UE_C = F.CODESC",
        "LEFT JOIN #ESCOLA G ON A.UE_E = G.CODESC",
        "LEFT JOIN #ARQ H ON A.UE_E = H.UA",
        "LEFT JOIN [00_CATEG] I ON A.CATEG_C = I.CATEG",
        "LEFT JOIN #CGRHANT J ON A.ID = J.ID_INTERNO",
        "LEFT JOIN #CGRHANT K ON A.ID = K.ID_INTERNO",
        "LEFT JOIN [00_CATEG] L ON A.CATEG_C = L.CATEG",
        "LEFT JOIN #BFE M ON A.INTERRUP = M.COD",
        "LEFT JOIN #BFE N ON A.MOTIAFAS = N.COD",
        "LEFT JOIN #BFE O ON A.MOTILICE = O.COD",
        "LEFT JOIN #BFE P ON A.MOT_INTERRUP_COMIS = P.COD",
        "LEFT JOIN #BFE Q ON A.MOTIAFAS_COMIS = Q.COD",
        "LEFT JOIN #BFE R ON A.MOTILICE_COMIS = R.COD",
        "LEFT JOIN #BFE S ON A.CD_MOT_SUBST_DESIGN = S.COD",
        "LEFT JOIN #CARGO T ON A.CARGO_COMIS = T.CD_CARGO",
        "LEFT JOIN [00_CATEG] U ON A.CATEG_COMIS = U.CATEG",
        "LEFT JOIN #ARQ V ON A.UA_C_COMIS = V.UA",
        "LEFT JOIN #ESCOLA W ON A.UE_C_COMIS = W.CODESC",
        "LEFT JOIN #ARQ X ON A.UA_E_COMIS = X.UA",
        "LEFT JOIN #ESCOLA Y ON A.UE_E_COMIS = Y.CODESC",
        "LEFT JOIN #CARGO Z ON A.CARGO_DESIGN = Z.CD_CARGO",
        "LEFT JOIN #ARQ AA ON A.UA_C_DESIGN = AA.UA",
        "LEFT JOIN #ESCOLA AB ON A.UE_C_DESIGN = AB.CODESC",
        "LEFT JOIN #DISC AC ON CONVERT(VARCHAR(100), A.CLDISC) = CONVERT(VARCHAR(100), AC.COD_DISCIPLINA)",
        "ORDER BY A.UA_C, A.NOMEUA_C",
        "",
        "---------------------------------------------------------------------------------------------------- #JOIN3 --------------------------------------------------",
        "",
        "DROP TABLE IF EXISTS #JOIN3",
        "SELECT DISTINCT",
        "    A.SITUACAO,",
        "    A.ID,",
        "    CONVERT(BIGINT, A.CPF) AS CPF ,",
        "    A.DI,",
        "    COALESCE(A.NOME, '') AS NOME, ",
        "    A.POLO_C,",
        "    A.REGIAO_C,",
        "    A.URE_C,",
        "    A.MUNICIPIO_C,",
        "    A.UA_C,",
        "    A.NOMEUA_C,",
        "    A.UE_C,",
        "    A.NOMEESC_C,",
        "    A.CARGO_C,",
        "    A.NOMECARGO_C,",
        "    A.QUADRO_C,",
        "    A.CATEG_C,",
        "    A.CATEG_C_DESC,",
        "    A.DTI_EXERC_C,",
        "    A.ANOS_TRAB_CARGO_C,",
        "    A.POLO_E,",
        "    A.REGIAO_E,",
        "    A.URE_E,",
        "    A.MUNICIPIO_E,",
        "    A.UA_E,",
        "    A.NOMEUA_E,",
        "    A.UE_E,",
        "    CASE",
        "       WHEN A.UE_E = '0' THEN ''",
        "       ELSE A.NOMEESC_E",
        "    END AS NOMEESC_E ,",
        "    A.CARGO_E,",
        "    A.NOMECARGO_E,",
        "    A.QUADRO_E,",
        "    A.CATEG_E,",
        "    A.CATEG_E_DESC,",
        "    A.DTI_EXERC_E,",
        "    A.SITESP,",
        "    A.DTI_SITESP,",
        "    A.INTERRUP,",
        "    A.INTERRUP_DESC,",
        "    A.DTI_INTERRUP,",
        "    A.DTF_INTERRUP,",
        "    A.MOTIAFAS,",
        "    A.MOTIAFAS_DESC,",
        "    A.DTI_MOTIAFAS,",
        "    A.DTF_MOTIAFAS,",
        "    A.MOTILICE,",
        "    A.MOTILICE_DESC,",
        "    A.DTI_MOTILICE,",
        "    A.DTF_MOTILICE,",
        "    COALESCE(B.POLO_C, '') AS POLO_COMIS ,",
        "    COALESCE(B.REGIAO_C, '') AS REGIAO_COMIS ,",
        "    COALESCE(B.NOMEDE_C, '') AS URE_COMIS ,",
        "    COALESCE(B.MUNICIPIO_C, '') AS MUNICIPIO_COMIS ,",
        "    A.UA_C_COMIS,",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.UA_C_COMIS = '0' THEN ''",
        "           ELSE A.NOMEUA_C_COMIS",
        "        END,",
        "        ''",
        "    ) AS NOMEUA_C_COMIS ,",
        "    A.UE_C_COMIS,",
        "    A.NOMEESC_C_COMIS,",
        "    A.UA_E_COMIS,",
        "    COALESCE(",
        "        CASE",
        "           WHEN A.UA_E_COMIS = '0' THEN ''",
        "           ELSE A.NOMEUA_E_COMIS",
        "        END,",
        "        ''",
        "    ) AS NOMEUA_E_COMIS ,",
        "    A.UE_E_COMIS,",
        "    A.NOMEESC_E_COMIS,",
        "    A.CARGO_COMIS,",
        "    A.CARGO_DESC,",
        "    A.CATEG_COMIS,",
        "    A.CATEG_COMIS_DESC,",
        "    A.DT_POSSE_COMIS,",
        "    A.DTI_EXERC_COMIS,",
        "    A.MOT_INTERRUP_COMIS,",
        "    A.MOT_INTERRUP_COMIS_DESC,",
