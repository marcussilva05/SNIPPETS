// SIC_2026051520185790
"SIC_2026051520185790": {
    "scope": "sql",
    "prefix": "ZSIC_2026051520185790",
    "body": [
        "/*",
        "",
        "SIC 2026051520185790",
        "",
        "SOLICITAÇÃO:",
        "Solicito informações sobre total de professores que foram afastados nas cidades de Campinas, Piracicaba, Limeira, Sumaré e Indaiatuba, nos anos de 2023, 2024, 2025 e 2026. Preciso desse dado separado por ano e por cidade, assim como pelos motivos de afastamento, incluindo por motivos de saúde mental.",
        "",
        "Prazo para resposta dia : 01/06/2026",
        "",
        "EMAIL:",
        "Daniele Gomes Silva",
        "21/05/2026 10H53",
        "",
        "BANCO:",
        "CEPEA_SAS",
        "",
        "TABELA:",
        "BFE0123 A 0326",
        "CTG0123 A 0326",
        "ARQDEUA0123 A 0326",
        "",
        "TEMPORÁRIA:",
        "#BASE_BFE",
        "#BASE_CTG",
        "",
        "*/",
        "",
        "--- #BASE_BFE",
        "DROP TABLE IF EXISTS #BASE_BFE",
        "SELECT *  INTO #BASE_BFE FROM CEPEA_SAS.dbo.BFE01${1:23}  WHERE CARGO IN (6407,6408,6409,5774,5776,5777)  ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362) UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE02${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777) ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362) UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE03${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777) ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362) UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE04${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777) ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362) UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE05${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777) ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362) UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE06${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777) ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362) UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE0723 WHERE CARGO IN (6407,6408,6409,5774,5776,5777) ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362) UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE08${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777)",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362)UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE0923 WHERE CARGO IN (6407,6408,6409,5774,5776,5777)",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362)UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE10${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777)",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362)UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE11${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777)",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362)UNION ALL",
        "SELECT *   FROM CEPEA_SAS.dbo.BFE12${1:23} WHERE CARGO IN (6407,6408,6409,5774,5776,5777) ",
        "AND  CODBFE IN (001 , 006, 257, 344, 350, 361, 485 , 380, 007, 103, 177 , 362)",
        "",
        "/*",
        "",
        "SELECT TOP 10*",
        "FROM #BASE_BFE",
        "ORDER BY CPF, DI ",
        "",
        "*/",
        "",
        "----- #BASE_CTG",
        "DROP TABLE IF EXISTS #BASE_CTG",
        "SELECT A.CODUA_E,",
        "       B.*,",
        "	   C.NOMEMUN",
        "INTO #BASE_CTG",
        "FROM CEPEA_SAS.dbo.CTG12${1:23} AS A ",
        "LEFT JOIN #BASE_BFE AS B",
        "ON A.CPF = B.CPF",
        "AND A.DI = B.DI",
        "LEFT JOIN CEPEA_SAS.DBO.ARQDEUA12${1:23} AS C",
        "ON A.CODUA_E = C.UA",
        "WHERE (NOMEMUN LIKE '%CAMPINAS%'",
        "OR NOMEMUN LIKE '%INDAIATUBA%'",
        "OR NOMEMUN LIKE '%LIMEIRA%'",
        "OR NOMEMUN LIKE '%PIRACICABA%'",
        "OR NOMEMUN LIKE '%SUMARE%') ",
        "AND B.CPF IS NOT NULL",
        "",
        "--(171548 linhas afetadas)",
        "--(161635 linhas afetadas)",
        "",
        "/*",
        "",
        "SELECT TOP 10*",
        "FROM #BASE_CTG",
        "ORDER BY CPF ",
        "",
        "*/",
        "",
        "SELECT NOMEMUN,",
        "       CODBFE,",
        "       COUNT(DOC) AS TT_DOC",
        "FROM(",
        "SELECT DISTINCT",
        "NOMEMUN,",
        "CASE",
        "   WHEN CODBFE IN ('001' ,'006', '257', '344', '350', '361' , '485', '380') THEN 'LICENÇA SAÚDE'",
        "   WHEN CODBFE IN ('007','103','177','362') THEN 'LICENÇA ACIDENTE DE TRABALHO'",
        "   ELSE CODBFE",
        "END AS CODBFE,",
        "CONCAT(CPF, DI) AS DOC",
        "FROM #BASE_CTG",
        "WHERE CONCAT(CPF, DI) IS NOT NULL OR CONCAT(CPF, DI) <> '') AS A ",
        "GROUP BY NOMEMUN, CODBFE",
        "ORDER BY NOMEMUN, CODBFE"
    ],
    "description": "SIC_AFASTAMENTO_PROFESSORES_2023_2026"
},

